generator client {
  provider      = "prisma-client-js"
  output        = "../../src/prisma-sqlite-client"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("TEST_DATABASE_URL")
}

enum Ruleset {
  season_2
  season_3
}

// Format de jeu : Blood Bowl à 11 ou à Sept (mirror du schéma PG principal).
enum Format {
  bb11
  sevens
}

model User {
  id                          String                      @id @default(cuid())
  email                       String                      @unique
  passwordHash                String
  name                        String? // Conservé pour rétrocompatibilité
  coachName                   String // Nom de coach (obligatoire)
  firstName                   String? // Prénom (optionnel)
  lastName                    String? // Nom (optionnel)
  dateOfBirth                 DateTime? // Date de naissance (optionnel)
  /// Rôle principal (conservé pour compatibilité, ex: "user" | "admin")
  role                        String                      @default("user")
  /// Liste complète des rôles (stockée en JSON, ex: '["user","admin"]')
  roles                       String                      @default("[]")
  /// Présent dans le schéma Postgres pour les fonctionnalités premium.
  /// Stub côté SQLite pour que /auth/me puisse sélectionner ce champ
  /// sans diverger entre les deux schémas.
  patreon                     Boolean                     @default(false)
  /// Code unique à coller dans le message Ko-fi pour lier le don au compte.
  kofiLinkCode                String?                     @unique
  /// Discord user ID renseigné par le titulaire du compte (3e stratégie de
  /// matching Ko-fi).
  discordUserId               String?                     @unique
  /// Palier (tier_name Ko-fi) du dernier abonnement actif.
  supporterTier               String?
  /// Fin de la période de supporter payée.
  supporterActiveUntil        DateTime?
  /// Map devise→centimes sérialisée en JSON (SQLite n'a pas de type Json).
  /// Exemple : '{"USD":300,"EUR":1000}'.
  totalDonatedCentsByCurrency String                      @default("{}")
  /// S26.3i — RGPD : opt-in pour cacher le profil public `/coach/{slug}`.
  /// Stub côté SQLite pour que la lookup publique puisse filtrer ce champ
  /// sans diverger entre les deux schémas.
  privateProfile              Boolean                     @default(false)
  /// Sprint R lot R.D.3 — NAF opt-in. Mirror PG.
  nafName                     String?
  /// Pré-alpha gate côté Postgres ; en SQLite tous les comptes sont valides.
  valid                       Boolean                     @default(true)
  /// Lot P.B.4 — moderation. Miroir des colonnes Postgres pour que les
  /// services admin/ban puissent etre testes en SQLite sans diverger.
  bannedAt                    DateTime?
  bannedUntil                 DateTime?
  banReason                   String?
  /// Lot P.C.2 — admin password reset override. Mirror du flag Postgres.
  mustChangePassword          Boolean                     @default(false)
  /// Lot P.A.2 — soft-delete RGPD-compatible. Mirror PG.
  deletedAt                   DateTime?
  deletionReason              String?
  /// Date de la dernière connexion réussie de l'utilisateur.
  lastLoginAt                 DateTime?
  /// Mirror PG — Visibilite dans le classement ELO ("visible" | "hidden_admin").
  leaderboardStatus           String                      @default("visible")
  leaderboardStatusReason     String?
  leaderboardStatusUpdatedAt  DateTime?
  leaderboardStatusUpdatedBy  String?
  createdAt                   DateTime                    @default(now())
  updatedAt                   DateTime                    @updatedAt
  matches                     Match[]
  createdMatches              Match[]                     @relation("MatchCreator")
  teams                       Team[]
  teamSelections              TeamSelection[]
  createdCups                 Cup[]                       @relation("CupCreator")
  createdLeagues              League[]                    @relation("LeagueCreator")
  createdLocalMatches         LocalMatch[]                @relation("LocalMatchCreator")
  eloRating                   Int                         @default(1000)
  matchQueue                  MatchQueue?
  featureFlagOverrides        FeatureFlagUser[]
  friendshipsSent             Friendship[]                @relation("FriendshipRequester")
  friendshipsReceived         Friendship[]                @relation("FriendshipReceiver")
  achievements                UserAchievement[]
  kofiTransactions            KofiTransaction[]
  refreshTokens               RefreshToken[]
  passwordResetTokens         PasswordResetToken[]
  eloSnapshots                EloSnapshot[]
  tutorialCompletions         TutorialCompletion[]
  proSpectatorFollows         ProSpectatorFollow[]
  proWallet                   ProWallet?
  proBets                     ProBet[]
  proUserBadges               ProUserBadge[]
  proHofDedications           ProHallOfFameDedication[]
  proPredictionLeagues        ProPredictionLeague[]
  proPredictionLeagueMembers  ProPredictionLeagueMember[]
  proPredictionPicks          ProPredictionPick[]
  proSurvivorEntries          ProSurvivorEntry[]
  proPlayerOfMatchVotes       ProPlayerOfMatchVote[]
  proGazetteComments          ProGazetteComment[]
  proMatchPredictions         ProMatchPrediction[]
  proTournamentEntries        ProTournamentEntry[]
  // Lot A — invitations envoyees / recues sur les ligues (mirror PG).
  leagueInvitationsSent       LeagueInvitation[]          @relation("LeagueInvitationInviter")
  leagueInvitationsReceived   LeagueInvitation[]          @relation("LeagueInvitationInvitee")
}

/// S26.3l — mirror SQLite de l'historique ELO Postgres (snapshot par mise a jour).
model EloSnapshot {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  rating     Int
  delta      Int
  matchId    String?
  recordedAt DateTime @default(now())

  @@index([userId, recordedAt])
}

/// S24.3c — mirror SQLite du registre Postgres des refresh tokens.
model RefreshToken {
  id        String    @id @default(cuid())
  jti       String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  requestIp String?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model KofiTransaction {
  id                         String    @id @default(cuid())
  kofiTransactionId          String    @unique
  messageId                  String?
  /// Horodatage Ko-fi (ISO 8601). Distinct de receivedAt.
  kofiTimestamp              DateTime?
  type                       String
  isSubscriptionPayment      Boolean   @default(false)
  isFirstSubscriptionPayment Boolean   @default(false)
  tierName                   String?
  amountCents                Int
  currency                   String
  fromName                   String?
  email                      String?
  /// discord_userid du payload Ko-fi (snowflake), conservé brut pour audit.
  discordUserId              String?
  message                    String?
  user                       User?     @relation(fields: [userId], references: [id])
  userId                     String?
  matchedVia                 String?
  /// SQLite n'a pas le type Json de Prisma : payload brut stocké en string.
  rawPayload                 String
  receivedAt                 DateTime  @default(now())

  @@index([userId])
  @@index([email])
  @@index([receivedAt])
}

/// S26 DoD — mirror SQLite du modele de telemetrie tutoriel (Postgres).
model TutorialCompletion {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  lessonSlug  String
  completedAt DateTime @default(now())

  @@unique([userId, lessonSlug])
  @@index([userId])
  @@index([lessonSlug])
}

// N.7 — Systeme d'achievements (mirror SQLite du schema Postgres).
model UserAchievement {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  slug       String
  unlockedAt DateTime @default(now())

  @@unique([userId, slug])
  @@index([userId])
}

// Relation d'amitie entre deux utilisateurs (mirror SQLite du schema Postgres)
model Friendship {
  id          String   @id @default(cuid())
  requester   User     @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  requesterId String
  receiver    User     @relation("FriendshipReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  receiverId  String
  status      String   @default("pending") // "pending" | "accepted" | "declined" | "blocked"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([requesterId, receiverId])
  @@index([requesterId])
  @@index([receiverId])
  @@index([status])
}

model FeatureFlag {
  id            String            @id @default(cuid())
  key           String            @unique
  description   String?
  enabled       Boolean           @default(false)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  userOverrides FeatureFlagUser[]
}

model FeatureFlagUser {
  id        String      @id @default(cuid())
  flag      FeatureFlag @relation(fields: [flagId], references: [id], onDelete: Cascade)
  flagId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime    @default(now())

  @@unique([flagId, userId])
  @@index([userId])
}

model Match {
  id                  String          @id @default(cuid())
  createdAt           DateTime        @default(now())
  status              String
  seed                String
  creator             User?           @relation("MatchCreator", fields: [creatorId], references: [id])
  creatorId           String?
  currentTurnUserId   String?
  lastMoveAt          DateTime?
  /// Sprint R lot R.E.1 — mode "realtime" (defaut) | "async". Mirror PG.
  mode                String          @default("realtime")
  currentTurnDeadline DateTime?
  turnDeadlineHours   Int             @default(24)
  players             User[]
  turns               Turn[]
  teamSelections      TeamSelection[]

  /// Lot P.B.4 — moderation matchs humains. Miroir des colonnes Postgres.
  forfeitedAt       DateTime?
  forfeitWinnerSide String?
  forfeitReason     String?
  cancelledAt       DateTime?
  cancelReason      String?

  // Practice vs AI — online match with an AI opponent.
  // Mirrors the same fields on the PostgreSQL schema so e2e-api tests that
  // hit `/match/*` routes don't fail with PrismaClientValidationError.
  aiOpponent   Boolean @default(false)
  aiDifficulty String?
  aiTeamSide   String?
  aiUserId     String?

  // L.7 / Sprint Ligues v2 — rattachement a une saison/journee/pairing
  // de ligue. Miroir du schema Postgres : sans ces champs, les services
  // qui font des includes (`pairings`, `leagueSeason`...) crashent
  // l'instance SQLite des e2e-api avec PrismaClientValidationError.
  leagueSeasonId          String?
  leagueSeason            LeagueSeason?            @relation("LeagueSeasonMatches", fields: [leagueSeasonId], references: [id])
  leagueRoundId           String?
  leagueRound             LeagueRound?             @relation("LeagueRoundMatches", fields: [leagueRoundId], references: [id])
  leaguePairingId         String?                  @unique
  leaguePairing           LeaguePairing?           @relation(fields: [leaguePairingId], references: [id])
  leagueScoredAt          DateTime?
  // Saisie offline brute + pre-valeurs pour la reversion (edition de resultat).
  offlineResultInput      Json?
  // L2.B.1 — Sprint Ligues v2 PR4 : sequence post-match Jeu en Ligue.
  leaguePostMatchSequence LeaguePostMatchSequence?

  @@index([aiOpponent])
  @@index([leagueSeasonId])
  @@index([leagueRoundId])
  @@index([mode, currentTurnDeadline])
}

model Turn {
  id        String   @id @default(cuid())
  match     Match    @relation(fields: [matchId], references: [id])
  matchId   String
  number    Int
  payload   Json
  createdAt DateTime @default(now())
}

model TeamSelection {
  id        String   @id @default(cuid())
  match     Match    @relation(fields: [matchId], references: [id])
  matchId   String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  team      String?
  teamRef   Team?    @relation(fields: [teamId], references: [id])
  teamId    String?
  createdAt DateTime @default(now())

  @@unique([matchId, userId])
  @@unique([matchId, teamId])
}

model Team {
  id                   String              @id @default(cuid())
  owner                User                @relation(fields: [ownerId], references: [id])
  ownerId              String
  name                 String
  roster               String
  ruleset              Ruleset             @default(season_3)
  format               Format              @default(bb11)
  createdAt            DateTime            @default(now())
  players              TeamPlayer[]
  starPlayers          TeamStarPlayer[]
  selections           TeamSelection[]
  cupParticipants      CupParticipant[]
  localMatchesAsTeamA  LocalMatch[]        @relation("LocalMatchTeamA")
  localMatchesAsTeamB  LocalMatch[]        @relation("LocalMatchTeamB")
  matchQueue           MatchQueue[]
  leagueParticipations LeagueParticipant[]
  // Lot A — invitations qui ciblent cette equipe specifique (mirror PG).
  leagueInvitations    LeagueInvitation[]

  // Informations d'équipe Blood Bowl
  treasury      Int     @default(0) // Trésorerie en pièces d'or (calculée automatiquement)
  rerolls       Int     @default(0) // Nombre de relances (0-8)
  cheerleaders  Int     @default(0) // Nombre de cheerleaders (0-12)
  assistants    Int     @default(0) // Nombre d'assistants (0-6)
  apothecary    Boolean @default(false) // Présence d'un apothicaire
  dedicatedFans Int     @default(1) // Nombre de fans dévoués (1-6)

  // Valeurs calculées automatiquement selon les règles Blood Bowl
  teamValue     Int @default(0) // VE - Valeur d'Équipe (calculée)
  currentValue  Int @default(0) // VEA - Valeur d'Équipe Actuelle (calculée)
  initialBudget Int @default(0) // Budget initial saisi par l'utilisateur lors de la création

  // Partage public opt-in (miroir SQLite de schema.prisma).
  isPublic   Boolean @default(false)
  shareToken String? @unique

  // Soft delete (miroir SQLite de schema.prisma).
  deletedAt DateTime?

  @@index([ownerId, deletedAt])
}

model TeamPlayer {
  id       String @id @default(cuid())
  team     Team   @relation(fields: [teamId], references: [id])
  teamId   String
  name     String
  position String
  number   Int
  ma       Int
  st       Int
  ag       Int
  pa       Int? // Passing (null pour - : certaines positions n'ont pas de passe)
  av       Int
  skills   String

  // SPP tracking (Star Player Points)
  spp                Int @default(0)
  totalTouchdowns    Int @default(0)
  totalCasualties    Int @default(0)
  totalCompletions   Int @default(0)
  totalInterceptions Int @default(0)
  totalMvpAwards     Int @default(0)
  matchesPlayed      Int @default(0)

  // Permanent injuries (BB2020/BB3 lasting injuries)
  nigglingInjuries Int     @default(0)
  maReduction      Int     @default(0)
  stReduction      Int     @default(0)
  agReduction      Int     @default(0)
  paReduction      Int     @default(0)
  avReduction      Int     @default(0)
  missNextMatch    Boolean @default(false)

  // Advancement tracking (level-up history)
  advancements String @default("[]") // JSON array of PlayerAdvancement objects

  // Player death tracking
  dead   Boolean   @default(false)
  diedAt DateTime?
}

// Star Player recruté pour une équipe (mirror minimal du schéma Postgres
// pour satisfaire les routes team qui font des includes sur cette relation).
model TeamStarPlayer {
  id             String   @id @default(cuid())
  team           Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId         String
  starPlayerSlug String
  cost           Int
  hiredAt        DateTime @default(now())

  @@unique([teamId, starPlayerSlug])
  @@index([teamId])
}

// Modèle pour les rosters d'équipes (mirror simplifié du schéma Postgres —
// on ne garde que les champs utilisés par les routes et par la sélection
// des linemen pour les journeymen).
model Roster {
  id            String   @id @default(cuid())
  slug          String
  ruleset       Ruleset  @default(season_2)
  name          String
  nameEn        String
  descriptionFr String?
  descriptionEn String?
  budget        Int
  tier          String
  regionalRules String?
  specialRules  String?
  naf           Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  positions    Position[]
  staffConfigs RosterStaffConfig[]

  @@unique([slug, ruleset])
}

// Mirror PG : config staff par roster ET par format (bb11 / sevens).
// Coûts en po entiers. Cf. schéma principal pour la doc complète.
model RosterStaffConfig {
  id                String   @id @default(cuid())
  roster            Roster   @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  rosterId          String
  format            Format
  rerollCost        Int
  maxRerolls        Int
  apothecaryAllowed Boolean
  apothecaryCost    Int
  maxCheerleaders   Int
  cheerleaderCost   Int
  maxAssistants     Int
  assistantCost     Int
  maxDedicatedFans  Int
  dedicatedFanCost  Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([rosterId, format])
  @@index([rosterId])
}

// Compétences BB3 (Skill). Utilisé par la route publique `/api/skills` et
// indirectement par `/api/positions` via la relation `PositionSkill` (read-only,
// jointure laissée vide en E2E sauf si un test seed explicitement la table).
model Skill {
  id            String   @id @default(cuid())
  slug          String
  ruleset       Ruleset  @default(season_2)
  nameFr        String
  nameEn        String
  description   String
  descriptionEn String?
  category      String
  isElite       Boolean  @default(false)
  isPassive     Boolean  @default(false)
  isModified    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  positionSkills PositionSkill[]

  @@unique([slug, ruleset])
}

// Positions rattachées à un roster (Lineman, Thrower, etc.).
// Utilisé par `getLinemanStats` pour peupler les journeymen et par
// `/api/positions` (qui inclut la relation `skills`).
model Position {
  id              String   @id @default(cuid())
  roster          Roster   @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  rosterId        String
  slug            String
  displayName     String
  cost            Int
  min             Int
  max             Int
  ma              Int
  st              Int
  ag              Int
  pa              Int? // Passing (null pour - : certaines positions n'ont pas de passe)
  av              Int
  keywords        String?
  primarySkills   String?
  secondarySkills String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  skills PositionSkill[]

  @@unique([rosterId, slug])
  @@index([rosterId])
}

// Relation many-to-many entre Position et Skill (miroir minimal du schéma
// Postgres). Nécessaire pour que la route `/api/positions` (qui fait
// `include: { skills: { include: { skill: true } } }`) ne crashe pas en E2E.
model PositionSkill {
  id         String   @id @default(cuid())
  position   Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  positionId String
  skill      Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  skillId    String

  @@unique([positionId, skillId])
  @@index([positionId])
}

// Modèle pour les coupes (tournois)
model Cup {
  id        String   @id @default(cuid())
  name      String // Nom de la coupe (obligatoire)
  creator   User     @relation("CupCreator", fields: [creatorId], references: [id])
  creatorId String
  ruleset   Ruleset  @default(season_2)
  validated Boolean  @default(false) // Si true, la coupe est validée et fermée aux inscriptions
  isPublic  Boolean  @default(true) // Si true, la coupe est publique et apparaît dans la liste
  status    String   @default("ouverte") // Statut: "ouverte", "en_cours", "terminee", "archivee"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Configuration des points (cf. schema Postgres). Necessaire pour
  // que `POST /cup` ne crashe pas en E2E (le route fait un create avec
  // ces champs explicitement).
  winPoints           Int @default(1000)
  drawPoints          Int @default(400)
  lossPoints          Int @default(0)
  forfeitPoints       Int @default(-100)
  touchdownPoints     Int @default(5)
  blockCasualtyPoints Int @default(3)
  foulCasualtyPoints  Int @default(2)
  passPoints          Int @default(2)

  // Relations
  participants CupParticipant[]
  localMatches LocalMatch[]

  @@index([creatorId])
  @@index([validated])
  @@index([isPublic])
  @@index([status])
}

// Relation many-to-many entre Cup et Team (participants)
model CupParticipant {
  id        String   @id @default(cuid())
  cup       Cup      @relation(fields: [cupId], references: [id], onDelete: Cascade)
  cupId     String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId    String
  createdAt DateTime @default(now())

  @@unique([cupId, teamId])
  @@index([cupId])
  @@index([teamId])
}

// Modèle pour la file d'attente de matchmaking
model MatchQueue {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @unique // Un seul slot par utilisateur
  team      Team     @relation(fields: [teamId], references: [id])
  teamId    String
  teamValue Int // Valeur d'equipe au moment de la recherche (pour matching TV +/- 150k)
  status    String   @default("searching") // "searching" | "matched" | "cancelled"
  matchId   String? // ID du match cree quand matched
  joinedAt  DateTime @default(now())

  @@index([status])
  @@index([teamValue])
}

// Réengagement — abonnement Web Push (mirror du schéma PG). Modèle
// autonome côté SQLite (pas de relation User stricte, comme les autres
// modèles périphériques du mirror) : les tests unitaires mockent prisma.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

// Réengagement Phase B — consentement digest e-mail (mirror du schéma
// PG). Modèle autonome côté SQLite ; tests unitaires mockent prisma.
model EmailDigestPreference {
  id             String    @id @default(cuid())
  userId         String    @unique
  enabled        Boolean   @default(false)
  lastSentAt     DateTime?
  unsubscribedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// Modèle pour les parties offline (Match Local)
model LocalMatch {
  id          String    @id @default(cuid())
  name        String? // Nom optionnel pour la partie
  status      String    @default("pending") // "pending", "waiting_for_player", "in_progress", "completed", "cancelled"
  // Miroir du schéma Postgres : la route `POST /local-match` set
  // `isPublic` explicitement, donc le champ doit exister en SQLite.
  isPublic    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  startedAt   DateTime? // Date de début de la partie
  completedAt DateTime? // Date de fin de la partie

  // Créateur de la partie
  creator   User   @relation("LocalMatchCreator", fields: [creatorId], references: [id])
  creatorId String

  // Les deux équipes qui s'affrontent
  teamA   Team    @relation("LocalMatchTeamA", fields: [teamAId], references: [id])
  teamAId String
  teamB   Team?   @relation("LocalMatchTeamB", fields: [teamBId], references: [id], onDelete: SetNull)
  teamBId String?

  // Relation optionnelle avec une coupe
  cup   Cup?    @relation(fields: [cupId], references: [id], onDelete: SetNull)
  cupId String?

  // Lien de partage pour inviter le second joueur
  shareToken String? @unique // Token unique pour le lien de partage

  // Validation de participation des propriétaires des équipes
  teamAOwnerValidated Boolean @default(false) // Le propriétaire de l'équipe A a validé sa participation
  teamBOwnerValidated Boolean @default(false) // Le propriétaire de l'équipe B a validé sa participation

  // État du jeu sauvegardé (JSON)
  gameState Json? // État complet du jeu pour reprise

  // Résultat du match (optionnel, rempli à la fin)
  scoreTeamA Int? // Score de l'équipe A
  scoreTeamB Int? // Score de l'équipe B

  // N.4 — Mode pratique contre IA.
  aiOpponent   Boolean @default(false)
  aiDifficulty String?
  aiTeamSide   String?

  // Actions manuelles enregistrées pour le match
  actions LocalMatchAction[]

  @@index([creatorId])
  @@index([teamAId])
  @@index([teamBId])
  @@index([cupId])
  @@index([status])
  @@index([createdAt])
  @@index([shareToken])
  @@index([aiOpponent])
}

// Modèle pour les actions manuelles d'un match local
model LocalMatchAction {
  id      String     @id @default(cuid())
  match   LocalMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId String

  // Informations sur l'action
  half       Int // Mi-temps (1 ou 2)
  turn       Int // Tour (1-8)
  actionType String // Type d'action: "passe", "reception", "td", "blocage", "blitz", "transmission", "aggression", "sprint", "esquive", "apothicaire", "interception"

  // Joueur qui effectue l'action
  playerId   String // ID du joueur (peut être un ID de joueur de l'équipe A ou B)
  playerName String // Nom du joueur (pour référence)
  playerTeam String // "A" ou "B"

  // Adversaire concerné (optionnel)
  opponentId   String? // ID du joueur adverse (si applicable)
  opponentName String? // Nom du joueur adverse (si applicable)

  // Résultat du dé (optionnel)
  diceResult Int? // Résultat du dé (1-6, ou autre selon le type d'action)

  // Échec (fumble)
  fumble Boolean @default(false) // Si true, l'action a échoué (fumble)

  // État du joueur en cas d'échec (sauf pour passe, transmission, réception, apothicaire, interception)
  playerState String? // État du joueur si l'action échoue: "sonne", "ko", "elimine"

  // Champs spécifiques pour blitz et blocage
  armorBroken   Boolean @default(false) // Si true, l'armure de l'adversaire est passée
  opponentState String? // État de l'adversaire si armure passée: "sonne", "ko", "elimine"

  // Champ spécifique pour passe
  passType String? // Type de passe: "rapide", "courte", "longue", "longue_bombe"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([matchId])
  @@index([half, turn])
  @@index([createdAt])
}

// L.1 — Modeles de ligue (Sprint 17). Mirror SQLite du schema Postgres.
model League {
  id                String   @id @default(cuid())
  name              String
  description       String?
  creator           User     @relation("LeagueCreator", fields: [creatorId], references: [id])
  creatorId         String
  ruleset           Ruleset  @default(season_3)
  status            String   @default("draft") // "draft" | "open" | "in_progress" | "completed" | "archived"
  isPublic          Boolean  @default(true)
  maxParticipants   Int      @default(16)
  allowedRosters    String? // JSON array des rosters autorises (null = tous)
  winPoints         Int      @default(3)
  drawPoints        Int      @default(1)
  lossPoints        Int      @default(0)
  forfeitPoints     Int      @default(-1)
  // L2.C.5 — Ordre de departage configurable (JSON array de slugs,
  // miroir PG).
  tieBreakRules     String?
  /// Lot E — Points bonus configurables. JSON serialise (sqlite mirror).
  bonusPointsConfig String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  seasons     LeagueSeason[]
  // Lot A — back-relation invitations envoyees pour cette ligue (mirror PG).
  invitations LeagueInvitation[]

  @@index([creatorId])
  @@index([status])
  @@index([isPublic])
}

model LeagueSeason {
  id            String    @id @default(cuid())
  league        League    @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  leagueId      String
  seasonNumber  Int
  name          String
  status        String    @default("draft") // "draft" | "scheduled" | "in_progress" | "completed"
  startDate     DateTime?
  endDate       DateTime?
  // S26.6 — themes saisonniers (cf. services/league-themes.ts).
  theme         String?
  themeYear     Int?
  // L2.C.3 — taille bracket playoffs (0 = disabled).
  playoffSize   Int       @default(0)
  // L2.B.5 — "Coup de mecene" activable par le commissaire (mirror PG).
  meceneEnabled Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  participants LeagueParticipant[]
  rounds       LeagueRound[]
  matches      Match[]             @relation("LeagueSeasonMatches")
  award        LeagueSeasonAward?
  // Lot C — poules optionnelles.
  pools        LeaguePool[]
  // Lot A — back-relation invitations ciblant cette saison precise (mirror PG).
  invitations  LeagueInvitation[]

  @@unique([leagueId, seasonNumber])
  @@index([leagueId])
  @@index([status])
  @@index([theme, themeYear])
}

/// Lot C — Poule (mirror PG).
model LeaguePool {
  id                   String       @id @default(cuid())
  season               LeagueSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  seasonId             String
  name                 String
  order                Int          @default(0)
  color                String?
  qualifiesForPlayoffs Int          @default(0)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  participants LeagueParticipant[]
  rounds       LeagueRound[]

  @@unique([seasonId, name])
  @@index([seasonId, order])
}

/// Lot A — Invitation a rejoindre une ligue (mirror PG de prisma/schema.prisma).
/// Sans cette table, l'e2e-api SQLite plante sur les requetes filtrant
/// `League.invitations` (Unknown argument `invitations`).
model LeagueInvitation {
  id                    String        @id @default(cuid())
  league                League        @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  leagueId              String
  season                LeagueSeason? @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  seasonId              String?
  inviter               User          @relation("LeagueInvitationInviter", fields: [inviterUserId], references: [id])
  inviterUserId         String
  invitee               User?         @relation("LeagueInvitationInvitee", fields: [inviteeUserId], references: [id])
  inviteeUserId         String?
  inviteeTeam           Team?         @relation(fields: [inviteeTeamId], references: [id])
  inviteeTeamId         String?
  inviteeEmail          String?
  /// "pending" | "accepted" | "declined" | "cancelled" | "expired"
  status                String        @default("pending")
  code                  String        @unique
  message               String?
  expiresAt             DateTime
  acceptedAt            DateTime?
  declinedAt            DateTime?
  cancelledAt           DateTime?
  /// Renseigne au moment de l'acceptation (utile si invitee != team owner).
  acceptedParticipantId String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([leagueId, status])
  @@index([inviteeUserId, status])
  @@index([code])
  @@index([expiresAt, status])
}

model LeagueParticipant {
  id                String       @id @default(cuid())
  season            LeagueSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  seasonId          String
  team              Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId            String
  seasonElo         Int          @default(1000)
  wins              Int          @default(0)
  draws             Int          @default(0)
  losses            Int          @default(0)
  points            Int          @default(0)
  touchdownsFor     Int          @default(0)
  touchdownsAgainst Int          @default(0)
  casualtiesFor     Int          @default(0)
  casualtiesAgainst Int          @default(0)
  status            String       @default("active") // "active" | "withdrawn"
  joinedAt          DateTime     @default(now())

  // L2.B.5 — Coup de mecene : bonus tresorerie 1x par saison.
  mecenePlayed   Boolean   @default(false)
  mecenePlayedAt DateTime?

  // Sprint Ligues v2 — back-relations vers les pairings (home/away)
  homePairings LeaguePairing[] @relation("LeaguePairingHome")
  awayPairings LeaguePairing[] @relation("LeaguePairingAway")

  // Lot C — affectation poule optionnelle (mirror PG).
  pool   LeaguePool? @relation(fields: [poolId], references: [id], onDelete: SetNull)
  poolId String?

  @@unique([seasonId, teamId])
  @@index([seasonId])
  @@index([teamId])
  @@index([seasonElo])
  @@index([seasonId, poolId])
}

model LeagueRound {
  id          String       @id @default(cuid())
  season      LeagueSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  seasonId    String
  roundNumber Int
  name        String?
  status      String       @default("pending") // "pending" | "in_progress" | "completed"
  // L2.C.3 — "regular" | "playoff" (mirror PG)
  kind        String       @default("regular")
  bracketSlot String?
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  matches  Match[]         @relation("LeagueRoundMatches")
  pairings LeaguePairing[]
  // Lot C — round optionnellement rattache a une poule (mirror PG).
  pool     LeaguePool?     @relation(fields: [poolId], references: [id], onDelete: SetNull)
  poolId   String?

  @@unique([seasonId, roundNumber])
  @@index([seasonId])
  @@index([status])
  @@index([seasonId, kind])
  @@index([seasonId, poolId, roundNumber])
}

// Sprint Ligues v2 (PR1) — pairing pre-genere du calendrier round-robin.
// Mirroir du schema Postgres : indispensable pour que les services qui
// font `prisma.leaguePairing.X(...)` ou des includes `rounds.pairings`
// fonctionnent contre la DB SQLite in-memory utilisee par les e2e-api.
model LeaguePairing {
  id                String            @id @default(cuid())
  round             LeagueRound       @relation(fields: [roundId], references: [id], onDelete: Cascade)
  roundId           String
  homeParticipant   LeagueParticipant @relation("LeaguePairingHome", fields: [homeParticipantId], references: [id], onDelete: Cascade)
  homeParticipantId String
  awayParticipant   LeagueParticipant @relation("LeaguePairingAway", fields: [awayParticipantId], references: [id], onDelete: Cascade)
  awayParticipantId String
  // "scheduled" | "in_progress" | "played" | "forfeit_home" | "forfeit_away" | "cancelled"
  status            String            @default("scheduled")
  scheduledAt       DateTime?
  deadlineAt        DateTime?
  match             Match?
  /// Lot E — Snapshot des points bonus appliques (mirror PG).
  bonusPointsHome   Int               @default(0)
  bonusPointsAway   Int               @default(0)
  /// Lot E — Breakdown JSON serialise (sqlite mirror).
  bonusBreakdown    String?
  /// Lot G — feuille de match v2 (1-1, mirror PG).
  matchSheet        LeagueMatchSheet?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([roundId])
  @@index([status])
  @@index([deadlineAt, status])
  @@index([homeParticipantId])
  @@index([awayParticipantId])
}

/// Lot G — Feuille de match v2 (mirror PG). Les champs Json PG sont
/// des String serialisees en sqlite.
model LeagueMatchSheet {
  id                     String        @id @default(cuid())
  pairing                LeaguePairing @relation(fields: [pairingId], references: [id], onDelete: Cascade)
  pairingId              String        @unique
  status                 String        @default("draft")
  submittedByHomeAt      DateTime?
  submittedByAwayAt      DateTime?
  validatedAt            DateTime?
  validatedById          String?
  invalidatedAt          DateTime?
  invalidationReason     String?
  weatherTable           String?
  weather                String?
  popularityHome         Int?
  popularityAway         Int?
  forfeitSide            String?
  inducementsHome        String?
  inducementsAway        String?
  prayersHome            String?
  prayersAway            String?
  scoreHome              Int           @default(0)
  scoreAway              Int           @default(0)
  winningsHome           Int           @default(0)
  winningsAway           Int           @default(0)
  winningsHomeManual     Int?
  winningsAwayManual     Int?
  dedicatedFansDeltaHome Int?
  dedicatedFansDeltaAway Int?
  rankingBonusHome       Int?
  rankingBonusAway       Int?
  sppBonus               String?
  costlyErrorsHome       String?
  costlyErrorsAway       String?
  motmPlayerIds          String        @default("[]")
  purchasesHome          String?
  purchasesAway          String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  events LeagueMatchEvent[]

  @@index([status])
}

/// Lot G — Evenement unitaire de feuille de match (mirror PG).
model LeagueMatchEvent {
  id             String           @id @default(cuid())
  matchSheet     LeagueMatchSheet @relation(fields: [matchSheetId], references: [id], onDelete: Cascade)
  matchSheetId   String
  kind           String
  team           String?
  actorPlayerId  String?
  targetPlayerId String?
  causeDetail    String?
  injurySeverity String?
  meta           String?
  occurredAt     DateTime         @default(now())

  @@index([matchSheetId, kind])
}

/// Catalogue des Règles Spéciales d'équipe (S3 — OCR officielle).
model TeamSpecialRule {
  id            String   @id @default(cuid())
  slug          String
  ruleset       Ruleset  @default(season_3)
  nameFr        String
  nameEn        String
  description   String
  descriptionEn String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([slug, ruleset])
}

/// Catalogue des Ligues régionales (S3 — OCR officielle).
model RegionalLeague {
  id            String   @id @default(cuid())
  slug          String
  ruleset       Ruleset  @default(season_3)
  nameFr        String
  nameEn        String
  description   String
  descriptionEn String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([slug, ruleset])
}

// L2.B.1 — Sprint Ligues v2 PR4 : sequence post-match Jeu en Ligue.
// Mirroir du schema Postgres (cf. prisma/schema.prisma) pour permettre
// aux services post-match (`prisma.leaguePostMatchSequence.X(...)`) de
// fonctionner contre la DB SQLite in-memory utilisee par les e2e-api.
model LeaguePostMatchSequence {
  id                     String    @id @default(cuid())
  match                  Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId                String    @unique
  seasonId               String
  status                 String    @default("pending")
  winningsApplied        Boolean   @default(false)
  lastingInjuriesApplied Boolean   @default(false)
  advancementsResolved   Boolean   @default(false)
  treasuryDeltaA         Int       @default(0)
  treasuryDeltaB         Int       @default(0)
  fanFactorDeltaA        Int       @default(0)
  fanFactorDeltaB        Int       @default(0)
  pendingChoices         String    @default("[]")
  createdAt              DateTime  @default(now())
  completedAt            DateTime?

  @@index([seasonId])
  @@index([status])
}

// L2.C.1 — Sprint Ligues v2 PR7 : awards de fin de saison (SQLite mirror).
model LeagueSeasonAward {
  id             String       @id @default(cuid())
  season         LeagueSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  seasonId       String       @unique
  championUserId String?
  championTeamId String?
  awards         String       @default("{}")
  createdAt      DateTime     @default(now())

  @@index([championUserId])
}

// Feedback public (SQLite mirror). Cf. prisma/schema.prisma pour la
// documentation du modele.
model Feedback {
  id        String   @id @default(cuid())
  type      String
  name      String?
  email     String?
  subject   String
  message   String
  userAgent String?
  pageUrl   String?
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([createdAt])
}

// =============================================================
// Pro League — sprint Pro League lot 1.A.1 (sqlite mirror)
// =============================================================
// Cf. /prisma/schema.prisma pour la documentation. Ce mirror sqlite
// remplace les colonnes `Json` par `String` (sqlite supporte JSON
// uniquement via JSON1 module — on serialise/parse cote application
// pour rester compatible).

model ProLeague {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  branding    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teams   ProTeam[]
  seasons ProLeagueSeason[]
}

model ProTeam {
  id             String    @id @default(cuid())
  league         ProLeague @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  leagueId       String
  slug           String    @unique
  city           String
  name           String
  race           String
  nflFlavor      String?
  primaryColor   String?
  secondaryColor String?
  baseTv         Int       @default(1000)
  meta           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  roster          ProTeamRoster[]
  homeMatches     ProLeagueMatch[]     @relation("ProMatchHome")
  awayMatches     ProLeagueMatch[]     @relation("ProMatchAway")
  standings       ProLeagueStandings[]
  followers       ProSpectatorFollow[]
  survivorEntries ProSurvivorEntry[]

  @@index([leagueId])
}

model ProTeamRoster {
  id          String   @id @default(cuid())
  team        ProTeam  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId      String
  name        String
  position    String
  ma          Int
  st          Int
  ag          Int
  pa          Int?
  av          Int
  skills      String   @default("[]")
  niggling    Int      @default(0)
  maReduction Int      @default(0)
  stReduction Int      @default(0)
  agReduction Int      @default(0)
  avReduction Int      @default(0)
  status      String   @default("active")
  form        Int      @default(50)
  careerStats String   @default("{}")
  // Lot 3.C.2 — Star Player Points + career counters.
  spp         Int      @default(0)
  tdCount     Int      @default(0)
  casCount    Int      @default(0)
  compCount   Int      @default(0)
  mvpCount    Int      @default(0)
  // Lot 3.C.4 — niveau du joueur (1..7) calcule depuis spp.
  level       Int      @default(1)
  // Lot 3.C.5 — TV individuelle (gold pieces) recomputee a chaque level-up.
  tvCached    Int      @default(50000)
  // Lot 4.D.1 — Stat increases (doubles roll au level-up).
  maBonus     Int      @default(0)
  agBonus     Int      @default(0)
  paBonus     Int      @default(0)
  avBonus     Int      @default(0)
  stBonus     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  careerSnapshot ProPlayerCareerSnapshot?
  mvpVotes       ProPlayerOfMatchVote[]

  @@index([teamId, status])
  @@index([teamId, spp])
  @@index([teamId, tvCached])
}

model ProLeagueSeason {
  id         String    @id @default(cuid())
  league     ProLeague @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  leagueId   String
  year       Int
  status     String    @default("scheduled")
  engineVer  String
  driverKind String    @default("hybrid")
  /// Sprint test-leagues — saison "test" cree depuis l'admin via la
  /// test-factory. `true` = la saison + tous ses matchs + standings sont
  /// invisibles cote user.
  isTest     Boolean   @default(false)
  /// Label libre pour les saisons test (ex: "Engine v2.1 regression").
  testLabel  String?
  startsAt   DateTime?
  endsAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  rounds          ProLeagueRound[]
  matches         ProLeagueMatch[]
  standings       ProLeagueStandings[]
  survivorEntries ProSurvivorEntry[]

  @@unique([leagueId, year])
  @@index([status])
  @@index([isTest])
}

model ProLeagueRound {
  id          String          @id @default(cuid())
  season      ProLeagueSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  seasonId    String
  roundNumber Int
  status      String          @default("pending")
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  matches         ProLeagueMatch[]
  survivorEntries ProSurvivorEntry[]

  @@unique([seasonId, roundNumber])
  @@index([status])
}

model ProLeagueMatch {
  id                  String          @id @default(cuid())
  season              ProLeagueSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  seasonId            String
  round               ProLeagueRound  @relation(fields: [roundId], references: [id], onDelete: Cascade)
  roundId             String
  homeTeam            ProTeam         @relation("ProMatchHome", fields: [homeTeamId], references: [id], onDelete: Cascade)
  homeTeamId          String
  awayTeam            ProTeam         @relation("ProMatchAway", fields: [awayTeamId], references: [id], onDelete: Cascade)
  awayTeamId          String
  status              String          @default("scheduled")
  scheduledAt         DateTime
  simulatedAt         DateTime?
  completedAt         DateTime?
  casualtiesAppliedAt DateTime?
  /// Lot 3.C.2 — flag idempotence post-process SPP.
  sppAppliedAt        DateTime?
  /// Lot 2.C.1 — sandbox flag (matchs admin "test" exclus des stats).
  isTest              Boolean         @default(false)
  /// Lot 3.B.1 — override optionnel du driver (null = inherit season).
  driverKindOverride  String?
  seed                BigInt?
  engineVer           String?
  replayId            String?         @unique
  scoreHome           Int?
  scoreAway           Int?
  outcome             String?
  touchdownCount      Int?
  casualtyCount       Int?
  turnoverCount       Int?
  nuffleCount         Int?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  betMarkets      ProBetMarket[]
  predictionPicks ProPredictionPick[]
  mvpVotes        ProPlayerOfMatchVote[]
  fanPredictions  ProMatchPrediction[]

  @@index([seasonId, status])
  @@index([roundId])
  @@index([scheduledAt])
  @@index([homeTeamId])
  @@index([awayTeamId])
}

model ProLeagueStandings {
  id                String          @id @default(cuid())
  season            ProLeagueSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  seasonId          String
  team              ProTeam         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId            String
  played            Int             @default(0)
  wins              Int             @default(0)
  draws             Int             @default(0)
  losses            Int             @default(0)
  points            Int             @default(0)
  tdFor             Int             @default(0)
  tdAgainst         Int             @default(0)
  casualtiesFor     Int             @default(0)
  casualtiesAgainst Int             @default(0)
  form              String          @default("[]")
  updatedAt         DateTime        @updatedAt

  @@unique([seasonId, teamId])
  @@index([seasonId, points, tdFor])
}

model Replay {
  matchId     String   @id
  payload     Bytes
  highlights  String   @default("[]")
  durationMs  Int
  rawJsonSize Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProSpectatorFollow {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  team      ProTeam  @relation(fields: [proTeamId], references: [id], onDelete: Cascade)
  proTeamId String
  since     DateTime @default(now())
  createdAt DateTime @default(now())

  @@unique([userId, proTeamId])
  @@index([userId])
  @@index([proTeamId])
}

model ProWallet {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  crowns    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions ProTransaction[]
}

model ProTransaction {
  id        String    @id @default(cuid())
  wallet    ProWallet @relation(fields: [walletId], references: [userId], onDelete: Cascade)
  walletId  String
  type      String
  amount    Int
  ref       String?
  createdAt DateTime  @default(now())

  @@index([walletId, createdAt])
  @@index([type])
}

model ProBetMarket {
  id        String         @id @default(cuid())
  match     ProLeagueMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId   String
  type      String
  config    String
  status    String         @default("open")
  closesAt  DateTime
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  bets       ProBet[]
  settlement ProBetSettlement?

  @@unique([matchId, type])
  @@index([status, closesAt])
}

model ProBet {
  id           String       @id @default(cuid())
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  market       ProBetMarket @relation(fields: [marketId], references: [id], onDelete: Cascade)
  marketId     String
  selection    String
  stake        Int
  oddsAtPlace  Float
  status       String       @default("pending")
  payoutAmount Int?
  clientToken  String       @unique
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([userId, createdAt])
  @@index([marketId, status])
  @@index([status])
}

model ProBetSettlement {
  id               String       @id @default(cuid())
  market           ProBetMarket @relation(fields: [marketId], references: [id], onDelete: Cascade)
  marketId         String       @unique
  winningSelection String
  totalStake       Int          @default(0)
  totalPayout      Int          @default(0)
  betCount         Int          @default(0)
  settledAt        DateTime     @default(now())
}

model ProUserBadge {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  badgeCode String
  earnedAt  DateTime @default(now())
  meta      String?

  @@unique([userId, badgeCode])
  @@index([badgeCode])
  @@index([userId])
}

model ProGazetteArticle {
  id               String   @id @default(cuid())
  date             DateTime
  type             String
  persona          String?
  title            String
  body             String
  relatedTeamIds   String?
  relatedPlayerIds String?
  createdAt        DateTime @default(now())

  comments ProGazetteComment[]

  @@index([date])
  @@index([type, date])
}

model ProHallOfFame {
  id          String                    @id @default(cuid())
  rosterId    String
  teamSlug    String
  teamName    String
  playerName  String
  race        String
  position    String
  ma          Int
  st          Int
  ag          Int
  pa          Int?
  av          Int
  skills      String
  careerStats String
  reason      String
  citation    String?
  inductedAt  DateTime                  @default(now())
  /// Sprint P (Lot P.B.2) — dedications fans payees en Crowns.
  dedications ProHallOfFameDedication[]

  @@unique([rosterId, reason])
  @@index([teamSlug])
  @@index([reason])
  @@index([inductedAt])
}

/// Sprint P (Lot P.B.2) — Dedications sur les entrees Hall of Fame.
/// Sink Crowns : un user paie 500 Crowns pour epingler un message
/// custom (max 280 chars) sur une entree HoF. 1 dedicace par user
/// par entree (unique[hallOfFameId, userId]). Sert de Crowns sink
/// pour prevenir l'hyperinflation introduite par les daily bonus +
/// gains de paris.
model ProHallOfFameDedication {
  id           String        @id @default(cuid())
  hallOfFameId String
  hallOfFame   ProHallOfFame @relation(fields: [hallOfFameId], references: [id], onDelete: Cascade)
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  message      String // max 280 chars (validated cote service)
  costCrowns   Int // montant debite (500 par defaut)
  createdAt    DateTime      @default(now())

  @@unique([hallOfFameId, userId])
  @@index([userId])
  @@index([hallOfFameId, createdAt])
}

// Lot P.B.2 — Tournois Pro League payants (sink Crowns).
model ProTournament {
  id             String               @id @default(cuid())
  slug           String               @unique
  name           String
  description    String?
  entryFeeCrowns Int                  @default(100)
  maxEntries     Int?
  status         String               @default("open")
  startsAt       DateTime?
  endsAt         DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  entries        ProTournamentEntry[]

  @@index([status, createdAt])
}

model ProTournamentEntry {
  id           String        @id @default(cuid())
  tournamentId String
  tournament   ProTournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  paidCrowns   Int
  createdAt    DateTime      @default(now())

  @@unique([tournamentId, userId])
  @@index([userId])
  @@index([tournamentId, createdAt])
}

// S27.6 — Audit log admin. Schema SQLite : `oldValue`/`newValue`
// stockes en String (JSON serialise) car SQLite n'a pas de type JSONB
// natif. Les helpers du service serialisent/parsent autour.
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldValue  String?
  newValue  String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([entity, entityId])
  @@index([action])
  @@index([createdAt])
}

// Lot 3.B.2 — Snapshot d'une comparaison hybrid vs full driver.
// Voir prisma/schema.prisma (postgres) pour la doc complete.
model EngineComparison {
  id                  String   @id @default(cuid())
  engineVer           String
  homeTeamId          String
  awayTeamId          String
  matches             Int
  seedOffset          Int
  meanScoreDelta      Float
  p95ScoreDelta       Float
  maxScoreDelta       Float
  meanTurnoverDelta   Float
  meanTouchdownDelta  Float
  meanCasualtyDelta   Float
  outcomeFlippedCount Int
  divergedPct         Float
  source              String   @default("admin")
  createdAt           DateTime @default(now())

  @@index([engineVer, createdAt])
  @@index([homeTeamId, awayTeamId, createdAt])
}

model ProPredictionLeague {
  id        String   @id @default(cuid())
  name      String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId   String
  joinCode  String   @unique
  isPrivate Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members ProPredictionLeagueMember[]
  picks   ProPredictionPick[]

  @@index([ownerId])
}

model ProPredictionLeagueMember {
  id       String              @id @default(cuid())
  league   ProPredictionLeague @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  leagueId String
  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  joinedAt DateTime            @default(now())

  @@unique([leagueId, userId])
  @@index([userId])
}

model ProPredictionPick {
  id        String              @id @default(cuid())
  league    ProPredictionLeague @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  leagueId  String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  match     ProLeagueMatch      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId   String
  selection String
  result    String?
  correct   Boolean?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([leagueId, userId, matchId])
  @@index([leagueId, matchId])
  @@index([userId, createdAt])
}

model ProSurvivorEntry {
  id           String          @id @default(cuid())
  season       ProLeagueSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  seasonId     String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  round        ProLeagueRound  @relation(fields: [roundId], references: [id], onDelete: Cascade)
  roundId      String
  weekN        Int
  pickedTeam   ProTeam         @relation(fields: [pickedTeamId], references: [id], onDelete: Cascade)
  pickedTeamId String
  status       String          @default("pending")
  result       String?
  matchId      String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([seasonId, userId, roundId])
  @@unique([seasonId, userId, pickedTeamId])
  @@index([seasonId, weekN])
  @@index([userId, seasonId])
  @@index([status])
}

model ProPlayerCareerSnapshot {
  id                 String        @id @default(cuid())
  player             ProTeamRoster @relation(fields: [playerId], references: [id], onDelete: Cascade)
  playerId           String        @unique
  matchesPlayed      Int           @default(0)
  tdTotal            Int           @default(0)
  casTotal           Int           @default(0)
  compTotal          Int           @default(0)
  mvpTotal           Int           @default(0)
  sppTotal           Int           @default(0)
  bestMatchId        String?
  bestMatchSpp       Int?
  worstMatchId       String?
  worstMatchSpp      Int?
  topNemesisTeamId   String?
  topVictoryTeamId   String?
  topMatchesJson     Json?
  topNemesisIdsJson  Json?
  topVictoryIdsJson  Json?
  casualtiesReceived Int           @default(0)
  casualtiesDealt    Int           @default(0)
  streakKind         String        @default("none")
  streakLength       Int           @default(0)
  recomputedAt       DateTime      @default(now())
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([recomputedAt])
}

model ProPlayerOfMatchVote {
  id            String         @id @default(cuid())
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  match         ProLeagueMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId       String
  votedRoster   ProTeamRoster  @relation(fields: [votedRosterId], references: [id], onDelete: Cascade)
  votedRosterId String
  createdAt     DateTime       @default(now())

  @@unique([userId, matchId])
  @@index([matchId, votedRosterId])
  @@index([votedRosterId, createdAt])
}

model ProGazetteComment {
  id         String            @id @default(cuid())
  article    ProGazetteArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId  String
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  body       String
  deletedAt  DateTime?
  flaggedAt  DateTime?
  flagReason String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([articleId, createdAt])
  @@index([userId, createdAt])
  @@index([flaggedAt])
  @@index([deletedAt])
}

model ProMatchPrediction {
  id        String         @id @default(cuid())
  match     ProLeagueMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId   String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  body      String
  score     String?
  scoredAt  DateTime?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([matchId, userId])
  @@index([matchId, createdAt])
  @@index([userId, score])
}

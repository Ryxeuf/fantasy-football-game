// TODO: brancher Postgres + Prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Ruleset {
  season_2
  season_3
}

// Format de jeu : Blood Bowl à 11 (classique) ou Blood Bowl à Sept.
// Axe orthogonal au Ruleset (édition des règles). Pilote les contraintes
// de sélection d'équipe (budget, nombre de joueurs, staff…) — cf.
// packages/game-engine FORMAT_CONSTRAINTS.
enum Format {
  bb11
  sevens
}

model User {
  id                          String                      @id @default(cuid())
  email                       String                      @unique
  passwordHash                String
  name                        String? // Conservé pour rétrocompatibilité
  coachName                   String // Nom de coach (obligatoire)
  firstName                   String? // Prénom (optionnel)
  lastName                    String? // Nom (optionnel)
  dateOfBirth                 DateTime? // Date de naissance (optionnel)
  /// Rôle principal (conservé pour compatibilité, ex: "user" | "admin")
  role                        String                      @default("user")
  /// Liste complète des rôles (ex: ["user","admin"])
  roles                       String[]                    @default([])
  /// Override manuel admin (cadeau, etc.). Conservé pour compatibilité.
  /// Le statut de supporter réel se lit via supporterActiveUntil.
  patreon                     Boolean                     @default(false)
  /// Code unique à coller dans le message Ko-fi pour lier le don au compte.
  /// Format : "KFI-XXXXXX" (base32 Crockford).
  kofiLinkCode                String?                     @unique
  /// Discord user ID renseigné par le titulaire du compte (3e stratégie de
  /// matching Ko-fi : si Ko-fi expose discord_userid et qu'il correspond, on
  /// rattache le don automatiquement).
  discordUserId               String?                     @unique
  /// Palier (tier_name Ko-fi) du dernier abonnement actif. null = pas d'abo.
  supporterTier               String?
  /// Fin de la période de supporter payée. null ou < now() = pas actif.
  supporterActiveUntil        DateTime?
  /// Total des dons par devise, en centimes. Map ISO currency → centimes.
  /// Pas de conversion : chaque devise reste indépendante (USD ≠ EUR).
  /// Exemple : {"USD": 300, "EUR": 1000}.
  totalDonatedCentsByCurrency Json                        @default("{}")
  /// S26.3i — RGPD : opt-in pour cacher le profil public `/coach/{slug}`.
  /// `true` = profil retire de la lookup publique et du sitemap.
  privateProfile              Boolean                     @default(false)
  /// Sprint R lot R.D.3 — NAF (Naffinity Federation) opt-in pour
  /// afficher les tournois IRL sur le profil coach. Identifiant NAF
  /// renseigne par le user (case-sensitive, ex: "Ryxeuf"). null = pas
  /// d'opt-in. Le service `naf-sync.ts` fetch les resultats via NAF API
  /// quand `naf_integration` flag est ON.
  nafName                     String?
  valid                       Boolean                     @default(false)
  /// Lot P.B.4 — moderation. Date de debut du dernier bannissement. null = jamais banni.
  bannedAt                    DateTime?
  /// Lot P.B.4 — fin du bannissement. Si > now() le user ne peut pas se logger.
  /// null = pas banni. Pour un ban permanent on stocke une date tres lointaine (year 9999).
  bannedUntil                 DateTime?
  /// Lot P.B.4 — raison du bannissement (visible admin uniquement).
  banReason                   String?
  /// Lot P.C.2 — admin password reset override. Si true, le user doit
  /// changer son mot de passe a la prochaine connexion. Mis a true par
  /// `POST /admin/users/:id/password-reset` ; remis a false des qu'un
  /// password change reussit (handler /auth/change-password).
  mustChangePassword          Boolean                     @default(false)
  /// Lot P.A.2 — soft-delete RGPD-compatible. Quand non-null, le compte
  /// est considere supprime : login refuse, profil public masque, mais
  /// les references foreign-key (audit log, replays, classements) sont
  /// preservees. Restaurable via /admin/users/:id/restore. Plus tard
  /// (lot dedie RGPD), un job purgera definitivement les comptes
  /// soft-deleted depuis > 30j.
  deletedAt                   DateTime?
  /// Lot P.A.2 — raison de la suppression (visible admin + audit log).
  deletionReason              String?
  /// Date de la dernière connexion réussie de l'utilisateur.
  lastLoginAt                 DateTime?
  /// Statut de visibilite dans le classement ELO public + sections ELO
  /// du profil coach. Valeurs : "visible" (defaut) | "hidden_admin".
  /// `hidden_admin` masque le user du leaderboard et masque la section
  /// ELO / historique ELO sur `/coach/{slug}` ; un badge "Non classe"
  /// s'affiche en remplacement. Modifiable uniquement par un admin
  /// via PATCH /admin/users/:id/leaderboard-status.
  leaderboardStatus           String                      @default("visible")
  /// Note admin libre (max 500 chars) sur le motif de masquage. Visible
  /// admin uniquement, sert d'audit interne.
  leaderboardStatusReason     String?
  /// Date de la derniere modification du `leaderboardStatus`.
  leaderboardStatusUpdatedAt  DateTime?
  /// userId de l'admin auteur du dernier changement de statut.
  leaderboardStatusUpdatedBy  String?
  createdAt                   DateTime                    @default(now())
  updatedAt                   DateTime                    @updatedAt
  matches                     Match[]
  createdMatches              Match[]                     @relation("MatchCreator")
  teams                       Team[]
  teamSelections              TeamSelection[]
  createdCups                 Cup[]                       @relation("CupCreator")
  createdLeagues              League[]                    @relation("LeagueCreator")
  createdLocalMatches         LocalMatch[]                @relation("LocalMatchCreator")
  eloRating                   Int                         @default(1000) // ELO rating for ranked matchmaking
  matchQueue                  MatchQueue?
  notificationPreference      NotificationPreference?
  pushSubscriptions           PushSubscription[]
  emailDigestPreference       EmailDigestPreference?
  featureFlagOverrides        FeatureFlagUser[]
  friendshipsSent             Friendship[]                @relation("FriendshipRequester")
  friendshipsReceived         Friendship[]                @relation("FriendshipReceiver")
  achievements                UserAchievement[]
  kofiTransactions            KofiTransaction[]
  refreshTokens               RefreshToken[]
  passwordResetTokens         PasswordResetToken[]
  eloSnapshots                EloSnapshot[]
  tutorialCompletions         TutorialCompletion[]
  proSpectatorFollows         ProSpectatorFollow[]
  proWallet                   ProWallet?
  proBets                     ProBet[]
  proUserBadges               ProUserBadge[]
  proHofDedications           ProHallOfFameDedication[]
  proPredictionLeagues        ProPredictionLeague[]
  proPredictionLeagueMembers  ProPredictionLeagueMember[]
  proPredictionPicks          ProPredictionPick[]
  proSurvivorEntries          ProSurvivorEntry[]
  proPlayerOfMatchVotes       ProPlayerOfMatchVote[]
  proGazetteComments          ProGazetteComment[]
  proMatchPredictions         ProMatchPrediction[]
  proTournamentEntries        ProTournamentEntry[]
  blogPosts                   BlogPost[]                  @relation("BlogPostAuthor")
  // Lot A — invitations envoyees / recues sur les ligues.
  leagueInvitationsSent       LeagueInvitation[]          @relation("LeagueInvitationInviter")
  leagueInvitationsReceived   LeagueInvitation[]          @relation("LeagueInvitationInvitee")

  @@index([leaderboardStatus])
}

/// S26.3l — Historique ELO du coach. Une ligne par mise a jour ELO (donc 2
/// par match termine en ranked). Sert a tracer la courbe 90j sur la page
/// publique `/coach/{slug}` sans avoir a recalculer l'ELO retroactivement.
/// `matchId` est nullable pour preserver l'historique meme si le match est
/// supprime ulterieurement.
model EloSnapshot {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  /// ELO du coach apres application de cette mise a jour (clampe a 100).
  rating     Int
  /// Variation appliquee (`newRating - oldRating`, peut etre negative).
  delta      Int
  /// Match a l'origine du snapshot. Null si genere par un job batch ou un
  /// recalcul administratif.
  matchId    String?
  recordedAt DateTime @default(now())

  @@index([userId, recordedAt])
}

/// S24.3c — Registre des refresh tokens JWT.
/// Chaque refresh token signe un `jti` unique tracé ici. La rotation revoque
/// l'ancien jti et insère un nouveau record. La détection de réutilisation
/// (token revoqué présenté à nouveau) revoque tous les jti de l'utilisateur.
model RefreshToken {
  id        String    @id @default(cuid())
  /// JWT ID claim (jti). Unique, sert de clé de lookup et de blacklist.
  jti       String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  /// Expiration du token en horloge serveur (DateTime, distincte de l'`exp`
  /// du payload JWT qui est en secondes UNIX). Permet l'auto-éviction.
  expiresAt DateTime
  /// null = actif. DateTime = revoqué (rotation, logout, reuse detection).
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

/// Lot P.C.1 — token de password reset self-service. Genere a la
/// requete `POST /auth/forgot-password`, consomme par `POST
/// /auth/reset-password`.
///
/// Anti-enumeration : la route forgot retourne toujours 200 OK
/// peu importe si l'email existe. Le token est cree silencieusement
/// et logue cote serveur.
///
/// Securite :
///   - `token` est un secret 32 octets base64url (256 bits) hashe
///     SHA-256 dans la DB (jamais persisted en clair). Le plain text
///     est uniquement dans le lien d'email/log.
///   - Single-use : `usedAt` set des qu'un reset reussit ; toute
///     tentative ulterieure renvoie 400.
///   - Expiration : `expiresAt` = createdAt + 24h. Les tokens expires
///     sont rejetes et peuvent etre purges par un cron mensuel.
///   - Au reset reussi : tous les RefreshToken du user sont revoqued
///     (force re-login).
model PasswordResetToken {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  /// SHA-256 hex du token plain text. Lookup via `where: { tokenHash }`.
  tokenHash String    @unique
  /// Date d'expiration absolue (createdAt + 24h).
  expiresAt DateTime
  /// null = inutilise. DateTime = consomme (single-use).
  usedAt    DateTime?
  /// IP a la requete forgot, audit forensique. Optionnel.
  requestIp String?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

/// Journal des événements webhook Ko-fi reçus.
/// userId est nullable : les dons orphelins sont rattachés au login suivant
/// si l'email ou le kofiLinkCode correspondent.
model KofiTransaction {
  id                         String    @id @default(cuid())
  /// Ko-fi "kofi_transaction_id" — UUID unique, sert à la déduplication.
  kofiTransactionId          String    @unique
  /// Ko-fi "message_id" — id d'événement propre à la notif (distinct de la transaction).
  messageId                  String?
  /// Horodatage fourni par Ko-fi dans le payload (ISO 8601). Distinct de
  /// receivedAt (= now()) pour pouvoir trier sur l'horloge Ko-fi en cas de
  /// retry tardif. null si parse échoue ou si payload pré-migration.
  kofiTimestamp              DateTime?
  /// "Donation" | "Subscription" | "Commission" | "Shop Order"
  type                       String
  isSubscriptionPayment      Boolean   @default(false)
  isFirstSubscriptionPayment Boolean   @default(false)
  /// tier_name pour les abonnements mensuels (Gold Member, etc.).
  tierName                   String?
  /// Montant en centimes dans la devise d'origine (ex 500 pour 5.00 EUR).
  amountCents                Int
  currency                   String
  fromName                   String?
  /// Stocké en lowercase pour le matching.
  email                      String?
  /// discord_userid du payload Ko-fi (snowflake). Conservé brut pour audit
  /// même quand le matching s'est fait par code ou email.
  discordUserId              String?
  message                    String?
  /// Rattachement au compte utilisateur. null = orphelin en attente de claim.
  user                       User?     @relation(fields: [userId], references: [id])
  userId                     String?
  /// "code" | "email" | "manual" | null
  matchedVia                 String?
  /// Payload brut pour diagnostic/rejeu.
  rawPayload                 Json
  receivedAt                 DateTime  @default(now())

  @@index([userId])
  @@index([email])
  @@index([receivedAt])
}

model FeatureFlag {
  id            String            @id @default(cuid())
  key           String            @unique
  description   String?
  enabled       Boolean           @default(false) // Interrupteur global
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  userOverrides FeatureFlagUser[]
}

model FeatureFlagUser {
  id        String      @id @default(cuid())
  flag      FeatureFlag @relation(fields: [flagId], references: [id], onDelete: Cascade)
  flagId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime    @default(now())

  @@unique([flagId, userId])
  @@index([userId])
}

model Match {
  id                String    @id @default(cuid())
  createdAt         DateTime  @default(now())
  status            String
  seed              String
  creator           User?     @relation("MatchCreator", fields: [creatorId], references: [id])
  creatorId         String?
  currentTurnUserId String? // Qui doit jouer actuellement
  lastMoveAt        DateTime? // Dernière action de jeu

  /// Sprint R lot R.E.1 — mode de jeu. "realtime" (defaut) ou "async".
  /// En mode async, pas de socket required : chaque coup est commit via
  /// REST `POST /match/:id/move`, et un cron deadline check force-end-turn
  /// si l'utilisateur ne joue pas dans le delai imparti.
  mode                String          @default("realtime")
  /// Sprint R lot R.E.1 — deadline pour le tour courant en mode async.
  /// Set par le hook move-processor a chaque move applique. null en mode
  /// realtime ou si le match n'est pas active.
  currentTurnDeadline DateTime?
  /// Sprint R lot R.E.1 — duree par tour en heures (default 24h). Permet
  /// aux ligues async de configurer leur rythme (12h speedrun vs 48h slow).
  turnDeadlineHours   Int             @default(24)
  players             User[]
  turns               Turn[]
  teamSelections      TeamSelection[]

  /// Lot P.B.4 — moderation. Date a laquelle un admin a force un forfait. null = pas de forfait.
  forfeitedAt       DateTime?
  /// Lot P.B.4 — cote du vainqueur ('A' ou 'B') quand un forfait admin est applique. null si pas forfeite.
  forfeitWinnerSide String?
  /// Lot P.B.4 — raison du forfait (visible admin + dans l'audit log). null si pas forfeite.
  forfeitReason     String?
  /// Lot P.B.4 — date a laquelle un admin a annule le match. null = pas annule.
  cancelledAt       DateTime?
  /// Lot P.B.4 — raison de l'annulation. null si pas annule.
  cancelReason      String?

  // Practice vs AI — online match with an AI opponent.
  aiOpponent   Boolean @default(false)
  aiDifficulty String? // 'easy' | 'medium' | 'hard'
  aiTeamSide   String? // 'A' | 'B' — side controlled by the AI
  aiUserId     String? // User id of the system AI account

  // L.7 — Rattachement a une saison/journee de ligue. Optionnel : un match
  // peut etre indepedant (amical, matchmaking classique) ou rattache a une
  // ligue. Quand les deux sont renseignes, la fin du match met a jour les
  // compteurs materialises du participant (wins/losses/points/td/cas).
  leagueSeasonId          String?
  leagueSeason            LeagueSeason?            @relation("LeagueSeasonMatches", fields: [leagueSeasonId], references: [id], onDelete: SetNull)
  leagueRoundId           String?
  leagueRound             LeagueRound?             @relation("LeagueRoundMatches", fields: [leagueRoundId], references: [id], onDelete: SetNull)
  // L2.A.1 — Lien optionnel vers le pairing pre-genere du calendrier
  // round-robin. Permet de remonter du match au pairing pour mettre a
  // jour son status (`scheduled` -> `in_progress` -> `played`) sans
  // chercher par (round, teamA, teamB). Unique : un pairing donne ne
  // genere qu'un seul match.
  leaguePairingId         String?                  @unique
  leaguePairing           LeaguePairing?           @relation(fields: [leaguePairingId], references: [id], onDelete: SetNull)
  // Marqueur d'idempotence pour recordLeagueMatchResult : une fois le score
  // reporte au classement, on ne le comptabilise plus, meme si la route/hook
  // est rejoue.
  leagueScoredAt          DateTime?
  // Saisie offline brute (RecordOfflineResultInput) + valeurs pre-applique
  // (ex: dedicatedFans avant clamp) necessaires a la REVERSION exacte lors
  // d'une edition de resultat. Set uniquement sur les Match `mode:"offline"`,
  // null pour les matchs joues en ligne.
  offlineResultInput      Json?
  // L2.B.1 — Sequence post-match Jeu en Ligue. 1 sequence par match
  // de ligue, cree apres recordLeagueMatchResult pour gerer le
  // applique-une-fois des winnings, SPP cumules, lasting injuries,
  // et la generation des pendingChoices de level-up.
  leaguePostMatchSequence LeaguePostMatchSequence?

  @@index([aiOpponent])
  @@index([leagueSeasonId])
  @@index([leagueRoundId])
  /// R.E.1 — index pour le cron deadline qui scan les async matches actifs.
  @@index([mode, currentTurnDeadline])
}

model Turn {
  id        String   @id @default(cuid())
  match     Match    @relation(fields: [matchId], references: [id])
  matchId   String
  number    Int
  payload   Json
  createdAt DateTime @default(now())
}

model TeamSelection {
  id        String   @id @default(cuid())
  match     Match    @relation(fields: [matchId], references: [id])
  matchId   String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  team      String   @default("")
  teamRef   Team?    @relation(fields: [teamId], references: [id])
  teamId    String?
  createdAt DateTime @default(now())

  @@unique([matchId, userId])
  @@unique([matchId, team])
  @@unique([matchId, teamId])
}

model Team {
  id                   String              @id @default(cuid())
  owner                User                @relation(fields: [ownerId], references: [id])
  ownerId              String
  name                 String
  roster               String // 'skaven' | 'lizardmen'
  ruleset              Ruleset             @default(season_3)
  format               Format              @default(bb11) // Blood Bowl à 11 ou à Sept
  createdAt            DateTime            @default(now())
  players              TeamPlayer[]
  starPlayers          TeamStarPlayer[]
  selections           TeamSelection[]
  cupParticipants      CupParticipant[]
  localMatchesAsTeamA  LocalMatch[]        @relation("LocalMatchTeamA")
  localMatchesAsTeamB  LocalMatch[]        @relation("LocalMatchTeamB")
  matchQueue           MatchQueue[]
  leagueParticipations LeagueParticipant[]
  // Lot A — invitations qui ciblent cette equipe specifique.
  leagueInvitations    LeagueInvitation[]

  // Informations d'équipe Blood Bowl
  treasury      Int     @default(0) // Trésorerie en pièces d'or (calculée automatiquement)
  rerolls       Int     @default(0) // Nombre de relances (0-8)
  cheerleaders  Int     @default(0) // Nombre de cheerleaders (0-12)
  assistants    Int     @default(0) // Nombre d'assistants (0-6)
  apothecary    Boolean @default(false) // Présence d'un apothicaire
  dedicatedFans Int     @default(1) // Nombre de fans dévoués (1-6)

  // Valeurs calculées automatiquement selon les règles Blood Bowl
  teamValue     Int @default(0) // VE - Valeur d'Équipe (calculée)
  currentValue  Int @default(0) // VEA - Valeur d'Équipe Actuelle (calculée)
  initialBudget Int @default(0) // Budget initial saisi par l'utilisateur lors de la création

  // Pool de PSP alloué à la construction (mode « édition avancée » du builder,
  // ou imposé par une coupe). Les advancements achetés au build ne dépensent
  // PAS `TeamPlayer.spp` (ils restent à 0) : ils puisent dans ce pool. La
  // fiche d'équipe affiche pool = `startingPspPool`, dépensés = Σ coûts des
  // advancements des joueurs, disponibles = pool − dépensés. 0 = comportement
  // historique (aucune amélioration au build).
  startingPspPool Int @default(0)

  // Partage public opt-in (boucle d'acquisition). Le coach active le
  // partage -> `shareToken` généré ; lien public en lecture seule via
  // /api/public/teams/:token. Désactivé par défaut (vie privée).
  isPublic   Boolean @default(false)
  shareToken String? @unique

  // Soft delete : un coach peut supprimer une équipe depuis sa liste. On ne
  // hard-delete pas car la Team reste référencée par l'historique des
  // compétitions (LeagueParticipant, CupParticipant) qu'on veut préserver.
  // `deletedAt = null` => active ; sinon masquée des listes du coach.
  deletedAt DateTime?

  @@index([ownerId, deletedAt])
}

model TeamPlayer {
  id       String @id @default(cuid())
  team     Team   @relation(fields: [teamId], references: [id])
  teamId   String
  name     String
  position String
  number   Int
  ma       Int
  st       Int
  ag       Int
  pa       Int? // Passing (null pour - : certaines positions n'ont pas de passe)
  av       Int
  skills   String

  // SPP tracking (Star Player Points)
  spp                Int @default(0) // Total SPP accumulated
  totalTouchdowns    Int @default(0) // Career touchdowns
  totalCasualties    Int @default(0) // Career casualties inflicted
  totalCompletions   Int @default(0) // Career pass completions
  totalInterceptions Int @default(0) // Career interceptions
  totalMvpAwards     Int @default(0) // Career MVP awards
  matchesPlayed      Int @default(0) // Total matches played

  // Permanent injuries (BB2020/BB3 lasting injuries)
  nigglingInjuries Int     @default(0) // Count of niggling injuries accumulated
  maReduction      Int     @default(0) // Total MA reduction from lasting injuries
  stReduction      Int     @default(0) // Total ST reduction from lasting injuries
  agReduction      Int     @default(0) // Total AG reduction from lasting injuries
  paReduction      Int     @default(0) // Total PA reduction from lasting injuries
  avReduction      Int     @default(0) // Total AV reduction from lasting injuries
  missNextMatch    Boolean @default(false) // Must sit out next match (seriously_hurt+)

  // Advancement tracking (level-up history)
  advancements String @default("[]") // JSON array of PlayerAdvancement objects

  // Player death tracking
  dead   Boolean   @default(false) // Player is dead (killed during a match)
  diedAt DateTime? // When the player died

  // Licenciement (ligue physique) : le joueur est retiré du roster actif
  // mais conservé en base (historique/carrière). `firedAt = null` => actif.
  firedAt DateTime? // When the player was fired (released) from the team

  @@index([teamId])
}

model TeamStarPlayer {
  id             String   @id @default(cuid())
  team           Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId         String
  starPlayerSlug String // Slug du Star Player (ex: 'griff_oberwald')
  cost           Int // Coût en po au moment du recrutement
  hiredAt        DateTime @default(now())

  @@unique([teamId, starPlayerSlug]) // Un même Star Player ne peut être recruté qu'une fois par équipe
  @@index([teamId])
}

// Modèle pour les compétences (skills)
model Skill {
  id            String   @id @default(cuid())
  slug          String // Identifiant unique (ex: "block", "dodge")
  ruleset       Ruleset  @default(season_2) // Ruleset de la compétence
  nameFr        String // Nom français (ex: "Blocage")
  nameEn        String // Nom anglais (ex: "Block")
  description   String // Description française de la compétence
  descriptionEn String? // Description anglaise de la compétence (optionnelle pour compatibilité)
  category      String // "General" | "Agility" | "Strength" | "Passing" | "Mutation" | "Trait" | "Scélérates"
  isElite       Boolean  @default(false) // Compétence Elite (+10 000 de valeur d'équipe)
  isPassive     Boolean  @default(false) // Compétence passive (soulignée)
  isModified    Boolean  @default(false) // Compétence modifiée ou nouveau nom (astérisque)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  positionSkills   PositionSkill[]
  starPlayerSkills StarPlayerSkill[]

  @@unique([slug, ruleset])
}

// Modèle pour les rosters d'équipes
model Roster {
  id            String   @id @default(cuid())
  slug          String // Identifiant unique (ex: "skaven", "lizardmen")
  ruleset       Ruleset  @default(season_2)
  name          String // Nom d'affichage en français (ex: "Skavens")
  nameEn        String // Nom d'affichage en anglais (ex: "Skaven")
  descriptionFr String? // Description en français
  descriptionEn String? // Description en anglais
  budget        Int // Budget de départ en kpo
  tier          String // "I" | "II" | "III" | "IV"
  regionalRules String? // Règles régionales (JSON array, ex: ["elven_kingdoms_league"])
  specialRules  String? // Règles spéciales (texte libre)
  naf           Boolean  @default(false) // Disponible dans NAF
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  positions    Position[]
  hirableBy    StarPlayerHirableBy[] // Règles régionales qui peuvent recruter des star players
  staffConfigs RosterStaffConfig[] // Config staff (relances, apothicaire, cheerleaders…) par format

  @@unique([slug, ruleset])
}

// Config staff d'équipe par roster ET par format (bb11 / sevens), saisie
// indépendamment pour chaque format. Source de vérité des coûts/plafonds de
// staff (relances, apothicaire, cheerleaders, coachs assistants, fans dévoués).
// Tous les coûts sont en **po entiers** (ex. 50000), comme `REROLL_COSTS` et
// `team-value-calculator`. Remplace les constantes codées en dur du package
// `@bb/game-engine` (REROLL_COSTS / FORMAT_CONSTRAINTS), qui restent le défaut
// de fallback si aucune ligne n'existe.
model RosterStaffConfig {
  id                String   @id @default(cuid())
  roster            Roster   @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  rosterId          String
  format            Format // "bb11" | "sevens"
  rerollCost        Int // Coût d'une relance d'équipe (po)
  maxRerolls        Int // Plafond de relances achetables
  apothecaryAllowed Boolean // L'apothicaire est-il recrutable pour ce roster ?
  apothecaryCost    Int // Coût de l'apothicaire (po)
  maxCheerleaders   Int
  cheerleaderCost   Int // po
  maxAssistants     Int // Coachs assistants
  assistantCost     Int // po
  maxDedicatedFans  Int
  dedicatedFanCost  Int // po (au-delà du 1er fan, gratuit)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([rosterId, format])
  @@index([rosterId])
}

// Modèle pour les positions dans les rosters
model Position {
  id              String   @id @default(cuid())
  roster          Roster   @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  rosterId        String
  slug            String // Slug unique (ex: "skaven_lineman")
  displayName     String // Nom d'affichage (ex: "Lineman")
  cost            Int // Coût en kpo
  min             Int // Minimum requis
  max             Int // Maximum autorisé
  ma              Int // Movement Allowance
  st              Int // Strength
  ag              Int // Agility
  pa              Int? // Passing (null pour - : certaines positions n'ont pas de passe)
  av              Int // Armour Value
  keywords        String? // Mots-clés séparés par des virgules (ex: "elite,passive")
  // Accès aux compétences en montée de niveau (BB Season 3). CSV de codes
  // catégorie "G,A,S,P,M". `null` = non renseigné (ex: season_2) → validation
  // désactivée. `""` = renseigné mais pool vide (ex: positions animales sans
  // accès primaire). Source : data/saison3/team/*.md (F=Force normalisé en S).
  primarySkills   String? // Catégories accessibles en primaire (ex: "G,S")
  secondarySkills String? // Catégories accessibles en secondaire (ex: "A")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  skills PositionSkill[]

  @@unique([rosterId, slug])
  @@index([rosterId])
}

// Relation many-to-many entre Position et Skill
model PositionSkill {
  id         String   @id @default(cuid())
  position   Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  positionId String
  skill      Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  skillId    String

  @@unique([positionId, skillId])
  @@index([positionId])
  @@index([skillId])
}

// Modèle pour les Star Players
model StarPlayer {
  id          String   @id @default(cuid())
  slug        String // Identifiant unique (ex: "griff_oberwald")
  ruleset     Ruleset  @default(season_2)
  displayName String // Nom d'affichage
  cost        Int // Coût en po (pièces d'or)
  ma          Int // Movement Allowance
  st          Int // Strength
  ag          Int // Agility (valeur cible, ex: 3 pour 3+)
  pa          Int? // Passing (valeur cible, ex: 2 pour 2+, null pour -)
  av          Int // Armour Value (valeur cible, ex: 9 pour 9+)
  specialRule String? // Règle spéciale du joueur
  imageUrl    String? // URL de l'image du joueur
  isMegaStar  Boolean  @default(false) // Flag Mega Star
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  skills    StarPlayerSkill[]
  hirableBy StarPlayerHirableBy[]

  @@unique([slug, ruleset])
}

// Relation many-to-many entre StarPlayer et Skill
model StarPlayerSkill {
  id           String     @id @default(cuid())
  starPlayer   StarPlayer @relation(fields: [starPlayerId], references: [id], onDelete: Cascade)
  starPlayerId String
  skill        Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)
  skillId      String

  @@unique([starPlayerId, skillId])
  @@index([starPlayerId])
  @@index([skillId])
}

// Relation many-to-many entre StarPlayer et Roster (pour les règles régionales)
model StarPlayerHirableBy {
  id           String     @id @default(cuid())
  starPlayer   StarPlayer @relation(fields: [starPlayerId], references: [id], onDelete: Cascade)
  starPlayerId String
  roster       Roster?    @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  rosterId     String?
  rule         String // Règle régionale (ex: "all", "old_world_classic", etc.)

  @@unique([starPlayerId, rosterId, rule])
  @@index([starPlayerId])
  @@index([rosterId])
  @@index([rule])
}

// Modèle pour les coupes (tournois)
model Cup {
  id          String  @id @default(cuid())
  name        String // Nom de la coupe (obligatoire)
  description String? // Description optionnelle affichée dans la liste des coupes
  creator     User    @relation("CupCreator", fields: [creatorId], references: [id])
  creatorId   String
  ruleset   Ruleset  @default(season_2)
  format    Format   @default(bb11) // Format imposé aux équipes (BB11 / Sevens)
  validated Boolean  @default(false) // Si true, la coupe est validée et fermée aux inscriptions
  isPublic  Boolean  @default(true) // Si true, la coupe est publique et apparaît dans la liste
  status    String   @default("ouverte") // Statut: "ouverte", "en_cours", "terminee", "archivee"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Configuration des points pour cette coupe
  /// Ces valeurs sont utilisées pour calculer le classement, mais
  /// les compteurs d'actions restent dérivés des matchs et ne sont pas éditables.
  winPoints     Int @default(1000) // Points pour une victoire
  drawPoints    Int @default(400) // Points pour un match nul
  lossPoints    Int @default(0) // Points pour une défaite
  forfeitPoints Int @default(-100) // Points pour un forfait

  touchdownPoints     Int @default(5) // Points par touchdown marqué
  blockCasualtyPoints Int @default(3) // Points par sortie sur blocage/blitz
  foulCasualtyPoints  Int @default(2) // Points par sortie sur agression
  passPoints          Int @default(2) // Points par passe réussie

  /// S27.1 — Mensualisation : edition canonique "Nuffle Cup {Mois} {YYYY}".
  /// Les deux champs sont nullable pour rester retro-compatibles avec les
  /// cups existantes (privees / non programmees). Quand fournis, ils
  /// doivent former un couple valide (1-12, annee positive). Validation
  /// applicable cote service `nuffle-cup-monthly.ts`.
  monthlyYear  Int?
  monthlyMonth Int?

  /// Règles avancées de composition (mode coupe). Tous optionnels /
  /// défaut neutre → une coupe sans config se comporte comme avant.
  ///
  /// `resurrectionMode` : à chaque match de coupe, l'équipe repart de son
  /// snapshot d'inscription (aucun PSP gagné, aucune blessure/mort/gain
  /// conservés — cf. `CupParticipant.rosterSnapshot`).
  resurrectionMode Boolean @default(false)

  /// Budget max par tier de roster, en kpo. JSON objet `{ "I": 1150,
  /// "II": 1100, "III": 1050, "IV": 1000 }`. Peut être un objet natif (PG)
  /// ou une string sérialisée (miroir sqlite en test) → parser tolérant
  /// côté `services/cup-rules.ts`. null = pas de contrainte par tier.
  tierBudgets Json?

  /// Surcharge de budget par roster précis (slug), en kpo. JSON objet
  /// `{ "skaven": 1200 }`. Prime sur `tierBudgets`. null = aucun override.
  rosterBudgetOverrides Json?

  /// Pool de PSP de départ par tier. JSON objet `{ "I": 0, "II": 6,
  /// "III": 10, "IV": 14 }`. Le coach dépense ce pool en améliorations au
  /// build. null / tier absent = 0 PSP.
  tierStartingPsp Json?

  /// Surcharge du pool de PSP par roster précis (slug). JSON objet
  /// `{ "skaven": 8 }`. Prime sur `tierStartingPsp`. null = aucun override.
  rosterStartingPspOverrides Json?

  // Relations
  participants CupParticipant[]
  localMatches LocalMatch[]

  @@index([creatorId])
  @@index([validated])
  @@index([isPublic])
  @@index([status])
  @@index([monthlyYear, monthlyMonth])
}

// Relation many-to-many entre Cup et Team (participants)
model CupParticipant {
  id        String   @id @default(cuid())
  cup       Cup      @relation(fields: [cupId], references: [id], onDelete: Cascade)
  cupId     String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId    String
  createdAt DateTime @default(now())

  /// Snapshot du roster tel qu'inscrit (joueurs + stats + skills +
  /// advancements). Sert de référence pour le mode résurrection (l'équipe
  /// repart de cet état à chaque match). Objet natif (PG) ou string (sqlite)
  /// → parser tolérant. null = participant historique sans snapshot.
  rosterSnapshot Json?

  /// Pool de PSP accordé à cette équipe pour cette coupe (trace / affichage).
  pspPoolGranted Int @default(0)

  @@unique([cupId, teamId])
  @@index([cupId])
  @@index([teamId])
}

// Modèle pour la file d'attente de matchmaking
model MatchQueue {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @unique // Un seul slot par utilisateur
  team      Team     @relation(fields: [teamId], references: [id])
  teamId    String
  teamValue Int // Valeur d'equipe au moment de la recherche (pour matching TV +/- 150k)
  status    String   @default("searching") // "searching" | "matched" | "cancelled"
  matchId   String? // ID du match cree quand matched
  joinedAt  DateTime @default(now())

  @@index([status])
  @@index([teamValue])
}

// Modèle pour les parties offline (Match Local)
model LocalMatch {
  id          String    @id @default(cuid())
  name        String? // Nom optionnel pour la partie
  status      String    @default("pending") // "pending", "waiting_for_player", "in_progress", "completed", "cancelled"
  isPublic    Boolean   @default(true) // Si true, le match est visible publiquement dans la liste
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  startedAt   DateTime? // Date de début de la partie
  completedAt DateTime? // Date de fin de la partie

  // Créateur de la partie
  creator   User   @relation("LocalMatchCreator", fields: [creatorId], references: [id])
  creatorId String

  // Les deux équipes qui s'affrontent
  teamA   Team    @relation("LocalMatchTeamA", fields: [teamAId], references: [id])
  teamAId String
  teamB   Team?   @relation("LocalMatchTeamB", fields: [teamBId], references: [id], onDelete: SetNull)
  teamBId String?

  // Relation optionnelle avec une coupe
  cup   Cup?    @relation(fields: [cupId], references: [id], onDelete: SetNull)
  cupId String?

  // Lien de partage pour inviter le second joueur
  shareToken String? @unique // Token unique pour le lien de partage

  // Validation de participation des propriétaires des équipes
  teamAOwnerValidated Boolean @default(false) // Le propriétaire de l'équipe A a validé sa participation
  teamBOwnerValidated Boolean @default(false) // Le propriétaire de l'équipe B a validé sa participation

  // État du jeu sauvegardé (JSON)
  gameState Json? // État complet du jeu pour reprise

  // Résultat du match (optionnel, rempli à la fin)
  scoreTeamA Int? // Score de l'équipe A
  scoreTeamB Int? // Score de l'équipe B

  // N.4 — Mode pratique contre IA.
  // `aiOpponent` flag indique que ce match est joue contre un adversaire IA.
  // `aiDifficulty` contient le profil de difficulte ('easy'|'medium'|'hard').
  // `aiTeamSide` indique quel cote est controle par l'IA ('A'|'B').
  aiOpponent   Boolean @default(false)
  aiDifficulty String?
  aiTeamSide   String?

  // Actions manuelles enregistrées pour le match
  actions LocalMatchAction[]

  /// S27.1f — Match-of-the-week. Picked by an admin to highlight the
  /// match on the home / cups landing pages. `featuredAt` est nullable :
  /// les matchs non featured restent retro-compatibles. Le pick est
  /// opt-in par admin (pas auto). `featuredNote` est un commentaire
  /// court FR/EN affiche sous le titre.
  featuredAt   DateTime?
  featuredNote String?

  @@index([creatorId])
  @@index([teamAId])
  @@index([teamBId])
  @@index([cupId])
  @@index([isPublic])
  @@index([status])
  @@index([createdAt])
  @@index([shareToken])
  @@index([aiOpponent])
  @@index([featuredAt])
}

// Modèle pour les actions manuelles d'un match local
model LocalMatchAction {
  id      String     @id @default(cuid())
  match   LocalMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId String

  // Informations sur l'action
  half       Int // Mi-temps (1 ou 2)
  turn       Int // Tour (1-8)
  actionType String // Type d'action: "passe", "reception", "td", "blocage", "blitz", "transmission", "aggression", "sprint", "esquive", "apothicaire", "interception"

  // Joueur qui effectue l'action
  playerId   String // ID du joueur (peut être un ID de joueur de l'équipe A ou B)
  playerName String // Nom du joueur (pour référence)
  playerTeam String // "A" ou "B"

  // Adversaire concerné (optionnel)
  opponentId   String? // ID du joueur adverse (si applicable)
  opponentName String? // Nom du joueur adverse (si applicable)

  // Résultat du dé (optionnel)
  diceResult Int? // Résultat du dé (1-6, ou autre selon le type d'action)

  // Échec (fumble)
  fumble Boolean @default(false) // Si true, l'action a échoué (fumble)

  // État du joueur en cas d'échec (sauf pour passe, transmission, réception, apothicaire, interception)
  playerState String? // État du joueur si l'action échoue: "sonne", "ko", "elimine"

  // Champs spécifiques pour blitz et blocage
  armorBroken   Boolean @default(false) // Si true, l'armure de l'adversaire est passée
  opponentState String? // État de l'adversaire si armure passée: "sonne", "ko", "elimine"

  // Champ spécifique pour passe
  passType String? // Type de passe: "rapide", "courte", "longue", "longue_bombe"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([matchId])
  @@index([half, turn])
  @@index([createdAt])
}

// Relation d'amitie entre deux utilisateurs
// status: "pending" (invitation envoyee, en attente de reponse)
//         "accepted" (amis)
//         "declined" (invitation refusee, conservee pour eviter le spam)
//         "blocked" (l'un a bloque l'autre)
// L'unicite (requesterId, receiverId) empeche les doublons dans un sens donne.
// Pour verifier si deux utilisateurs sont amis il faut chercher dans les deux sens.
model Friendship {
  id          String   @id @default(cuid())
  requester   User     @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  requesterId String
  receiver    User     @relation("FriendshipReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  receiverId  String
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([requesterId, receiverId])
  @@index([requesterId])
  @@index([receiverId])
  @@index([status])
}

/// S26 DoD — Telemetrie de progression tutoriel.
/// Un row par (userId, lessonSlug) cree quand l'utilisateur termine la lecon.
/// Sert a mesurer le KPI "80% des nouveaux comptes finissent au moins une lecon".
/// Idempotent : la route POST upsert pour eviter les doublons.
model TutorialCompletion {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  lessonSlug  String
  completedAt DateTime @default(now())

  @@unique([userId, lessonSlug])
  @@index([userId])
  @@index([lessonSlug])
}

// N.7 — Systeme d'achievements (succes). Un unlock par (userId, slug).
// Le catalogue complet est en code (apps/server/src/services/achievements.ts).
model UserAchievement {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  slug       String
  unlockedAt DateTime @default(now())

  @@unique([userId, slug])
  @@index([userId])
}

// Preferences de notification push par utilisateur
model NotificationPreference {
  id                              String  @id @default(cuid())
  user                            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                          String  @unique
  pushEnabled                     Boolean @default(true) // Master toggle notifications push
  turnNotification                Boolean @default(true) // "C'est votre tour de jouer !"
  matchFoundNotification          Boolean @default(true) // "Un adversaire a ete trouve !"
  friendMatchStartedNotification  Boolean @default(true) // S26.5 — "{ami} demarre un match contre {adversaire}"
  leagueRoundReminderNotification Boolean @default(true) // L2.A.12 — "Vous avez ete apparie a {coach} pour la J{n}"
}

/// Réengagement — abonnement Web Push (PWA) persisté.
///
/// Avant, les subscriptions web-push vivaient en mémoire (Map) : perdues
/// au restart serveur et non partagées entre instances, ce qui défait
/// l'objectif de réengagement (notifier un coach absent quand son match
/// async devient prêt). On les persiste désormais. `endpoint` est
/// globalement unique : un endpoint push appartient à un seul
/// navigateur/appareil. Au ré-abonnement depuis le même device, on
/// upsert (les clés p256dh/auth peuvent avoir tourné).
model PushSubscription {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

/// Réengagement — Phase B : consentement (opt-in) au digest e-mail
/// hebdomadaire + état d'idempotence.
///
/// RGPD : `enabled` est false par défaut (opt-in explicite requis). La
/// désinscription en un clic (token signé, sans login) pose
/// `enabled=false` + `unsubscribedAt`. `lastSentAt` sert de garde
/// d'idempotence : le job hebdo ne ré-envoie pas dans la fenêtre.
model EmailDigestPreference {
  id             String    @id @default(cuid())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String    @unique
  enabled        Boolean   @default(false)
  lastSentAt     DateTime?
  unsubscribedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// L.1 — Modele ligue (Sprint 17 : infrastructure competitive).
// Une League est le conteneur persistant. Chaque edition concrete
// est une LeagueSeason (round-robin, playoffs...).
/// Lot A — Invitation a rejoindre une ligue.
///
/// Le commissaire (createur de la ligue) ou un admin peut inviter
/// un coach (par userId, email, ou autre) a rejoindre une saison
/// donnee. L'invitation contient un code unique (sharable URL) +
/// statut + expiration. Si `inviteeUserId` est null, l'invitation
/// peut etre acceptee par le 1er user qui se connecte avec ce code
/// (lien public). Sinon, seul le user cible peut accepter.
model LeagueInvitation {
  id                    String        @id @default(cuid())
  league                League        @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  leagueId              String
  /// Optionnel : saison ciblee si l'invitation pointe sur une saison
  /// specifique. Si null, le coach choisira la saison a l'acceptation
  /// (utile pour les ligues avec plusieurs saisons en cours).
  season                LeagueSeason? @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  seasonId              String?
  /// Auteur de l'invitation (commissaire ou admin).
  inviter               User          @relation("LeagueInvitationInviter", fields: [inviterUserId], references: [id])
  inviterUserId         String
  /// Optionnel : coach cible identifie. Si null, lien d'invitation
  /// publique (1er user qui ouvre le lien et accepte).
  invitee               User?         @relation("LeagueInvitationInvitee", fields: [inviteeUserId], references: [id])
  inviteeUserId         String?
  /// Optionnel : equipe pre-selectionnee. Le coach pourra confirmer
  /// ou choisir une autre equipe lors de l'acceptation.
  inviteeTeam           Team?         @relation(fields: [inviteeTeamId], references: [id])
  inviteeTeamId         String?
  /// Optionnel : email cible quand l'invitation depasse les frontieres
  /// de la plateforme. Permet de prevoir un envoi mail (Lot futur).
  inviteeEmail          String?
  /// "pending" | "accepted" | "declined" | "cancelled" | "expired"
  status                String        @default("pending")
  /// Token unique pour partager le lien (publique mais inviolable).
  /// Format : alphanumeric ~24 chars (crypto.randomBytes(16).toString("base64url")).
  code                  String        @unique
  /// Message libre du commissaire ("Salut, rejoins la Skaven Cup !").
  message               String?
  expiresAt             DateTime
  acceptedAt            DateTime?
  declinedAt            DateTime?
  cancelledAt           DateTime?
  /// Renseigne au moment de l'acceptation (utile si invitee != team owner).
  acceptedParticipantId String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([leagueId, status])
  @@index([inviteeUserId, status])
  @@index([code])
  @@index([expiresAt, status])
}

model League {
  id                String   @id @default(cuid())
  name              String
  description       String?
  creator           User     @relation("LeagueCreator", fields: [creatorId], references: [id])
  creatorId         String
  ruleset           Ruleset  @default(season_3)
  // "draft" | "open" | "in_progress" | "completed" | "archived"
  status            String   @default("draft")
  isPublic          Boolean  @default(true)
  maxParticipants   Int      @default(16)
  // JSON array de slugs de rosters autorises. null = tous rosters autorises.
  // Ex: ["skaven","gnomes","lizardmen","dwarf","imperial_nobility"]
  // pour la ligue L.9 "Open 5 Teams".
  allowedRosters    String?
  // FR17 — JSON array de slugs de coups de pouce (inducements) autorises pour
  // la ligue. null = tous autorises (defaut). Les Star Players ne sont PAS
  // filtres par ce champ (ils dependent des rosters / regles regionales).
  allowedInducements String?
  winPoints         Int      @default(3)
  drawPoints        Int      @default(1)
  lossPoints        Int      @default(0)
  forfeitPoints     Int      @default(-1)
  // L2.C.5 — Ordre de departage configurable. JSON array de slugs
  // parmi : "points" / "td_diff" / "td_for" / "td_against" /
  // "cas_diff" / "cas_for" / "season_elo" / "wins" / "name".
  // null = ordre par defaut historique :
  //   ["points","td_diff","td_for","season_elo","name"].
  // L'ordre dans l'array dicte l'ordre de tri (le 1er = plus
  // important). Tous les slugs sauf "name" supportent reverse
  // (false = DESC, default ; pas exprimable dans le JSON pour
  // l'instant — toujours DESC sauf "name" qui est ASC).
  tieBreakRules     String?
  /// Lot E — Points bonus configurables (JSON array de regles, cf.
  /// `services/league-bonus-points.ts`). null = pas de bonus applique
  /// au scoring. Modifiable tant qu'aucun match n'a ete score.
  bonusPointsConfig Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  seasons     LeagueSeason[]
  // Lot A — back-relation invitations envoyees pour cette ligue.
  invitations LeagueInvitation[]

  @@index([creatorId])
  @@index([status])
  @@index([isPublic])
}

// L.1 — Saison de ligue. Une saison encapsule les participants,
// le calendrier et le classement pour une edition donnee.
// S26.6 — `theme` + `themeYear` : ligues thematiques saisonnieres
// (Skaven Cup mars, Nordic Challenge avril, Underworld Open mai).
model LeagueSeason {
  id            String    @id @default(cuid())
  league        League    @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  leagueId      String
  seasonNumber  Int
  name          String
  // "draft" | "scheduled" | "in_progress" | "completed"
  status        String    @default("draft")
  startDate     DateTime?
  endDate       DateTime?
  // S26.6 — slug du theme saisonnier (cf. services/league-themes.ts).
  // null si la saison n'est pas thematique (mode classique).
  theme         String?
  // S26.6 — annee canonique du theme (4 chiffres). Toujours present si
  // `theme` est present (couple atomique enforce par le service).
  themeYear     Int?
  // L2.C.3 — taille du bracket de playoffs (top N qualifies pour
  // l'elimination directe en fin de saison reguliere). 0 = pas de
  // playoff (mode classique : champion = 1er du round-robin).
  // Valeurs supportees : 0, 2 (final seulement), 4 (SF + final),
  // 8 (QF + SF + final). 16+ : non supporte pour l'instant.
  playoffSize   Int       @default(0)
  // L2.B.5 — "Coup de mecene" : option activable par le commissaire.
  // false par defaut => le bonus +100k po n'est PAS disponible pour les
  // coachs. Le commissaire l'active explicitement par saison.
  meceneEnabled Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  participants LeagueParticipant[]
  rounds       LeagueRound[]
  matches      Match[]             @relation("LeagueSeasonMatches")
  award        LeagueSeasonAward?
  // Lot A — back-relation invitations ciblant cette saison precise.
  invitations  LeagueInvitation[]
  // Lot C — multi-poules optionnelles. Vide = saison single-pool
  // (comportement legacy preserve : tout le monde dans la meme poule).
  pools        LeaguePool[]

  @@unique([leagueId, seasonNumber])
  @@index([leagueId])
  @@index([status])
  @@index([theme, themeYear])
}

/// Lot C — Poule d'une saison de ligue.
///
/// Une saison peut etre divisee en plusieurs poules pour les
/// championnats avec phase de groupes. Les participants sont
/// affectes a une poule via `LeagueParticipant.poolId`. Le
/// calendrier round-robin est genere par poule, mais les rounds
/// (journees) sont communes pour synchroniser le rythme.
///
/// `qualifiesForPlayoffs` permet de specifier combien d'equipes de
/// chaque poule iront en playoffs (top-N par poule).
model LeaguePool {
  id                   String       @id @default(cuid())
  season               LeagueSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  seasonId             String
  name                 String
  order                Int          @default(0)
  /// Couleur de presentation UI (hex `#RRGGBB`), optionnelle.
  color                String?
  /// Lot C — Combien d'equipes de cette poule sont qualifiees pour
  /// les playoffs. Default 0 = aucune. Le `startPlayoffs` lit ce
  /// champ et seed le bracket avec les top-N de chaque poule.
  qualifiesForPlayoffs Int          @default(0)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  participants LeagueParticipant[]
  rounds       LeagueRound[]

  @@unique([seasonId, name])
  @@index([seasonId, order])
}

// L.1 — Inscription d'une equipe sur une saison.
// Les compteurs (wins/draws/losses/points/td/cas) sont materialises
// pour servir le classement rapidement (L.3 standings, L.7 agregation
// des resultats). `seasonElo` supporte L.8 (ELO saisonnier).
model LeagueParticipant {
  id                String       @id @default(cuid())
  season            LeagueSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  seasonId          String
  team              Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId            String
  seasonElo         Int          @default(1000)
  wins              Int          @default(0)
  draws             Int          @default(0)
  losses            Int          @default(0)
  points            Int          @default(0)
  touchdownsFor     Int          @default(0)
  touchdownsAgainst Int          @default(0)
  casualtiesFor     Int          @default(0)
  casualtiesAgainst Int          @default(0)
  // "active" | "withdrawn"
  status            String       @default("active")
  joinedAt          DateTime     @default(now())

  // L2.B.5 — Coup de mecene : bonus tresorerie 1x par saison.
  mecenePlayed   Boolean   @default(false)
  mecenePlayedAt DateTime?

  // L2.A.1 — Back-relations vers les pairings ou ce participant est
  // implique comme equipe a domicile ou visiteuse.
  homePairings LeaguePairing[] @relation("LeaguePairingHome")
  awayPairings LeaguePairing[] @relation("LeaguePairingAway")

  // Lot C — poule d'affectation (optionnelle). null = single-pool.
  pool   LeaguePool? @relation(fields: [poolId], references: [id], onDelete: SetNull)
  poolId String?

  @@unique([seasonId, teamId])
  @@index([seasonId])
  @@index([teamId])
  @@index([seasonElo])
  @@index([seasonId, poolId])
}

// L.1 — Journee (round) d'une saison. Utilise par le generateur
// de calendrier round-robin (L.4) et le rattachement des matchs (L.7).
model LeagueRound {
  id          String       @id @default(cuid())
  season      LeagueSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  seasonId    String
  roundNumber Int
  name        String?
  // "pending" | "in_progress" | "completed"
  status      String       @default("pending")
  // L2.C.3 — type de round. "regular" (round-robin) ou "playoff"
  // (bracket d'elimination directe). Default "regular" pour
  // compatibilite avec les rounds Sprint 17 / PR1 existants.
  kind        String       @default("regular")
  // L2.C.3 — slot dans le bracket pour les rounds playoff. Format
  // libre conventionnel : "qf1".."qf4", "sf1".."sf2", "final".
  // Null pour les rounds reguliers.
  bracketSlot String?
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  matches  Match[]         @relation("LeagueRoundMatches")
  pairings LeaguePairing[]
  // Lot C — round optionnellement rattache a une poule (pour les
  // saisons multi-poules ou chaque poule a son propre calendrier).
  pool     LeaguePool?     @relation(fields: [poolId], references: [id], onDelete: SetNull)
  poolId   String?

  @@unique([seasonId, roundNumber])
  @@index([seasonId])
  @@index([status])
  @@index([seasonId, kind])
  @@index([seasonId, poolId, roundNumber])
}

// L2.A.1 — Pairing pre-genere du calendrier round-robin.
// Materialise une rencontre planifiee (home vs away) avant qu'un match
// concret ne soit cree. Le statut suit le cycle :
//   scheduled  -> aucun match cree
//   in_progress -> match cree (matchId renseigne) et en cours
//   played      -> match termine et resultat reporte au classement
//   forfeit_home / forfeit_away -> forfait cron-applique
//   cancelled   -> annule par admin
// La nullabilite de `matchId` permet d'afficher le calendrier complet
// avant que les matchs n'existent. `deadlineAt` alimente le cron de
// forfait (L2.A.11).
model LeaguePairing {
  id                String            @id @default(cuid())
  round             LeagueRound       @relation(fields: [roundId], references: [id], onDelete: Cascade)
  roundId           String
  homeParticipant   LeagueParticipant @relation("LeaguePairingHome", fields: [homeParticipantId], references: [id], onDelete: Cascade)
  homeParticipantId String
  awayParticipant   LeagueParticipant @relation("LeaguePairingAway", fields: [awayParticipantId], references: [id], onDelete: Cascade)
  awayParticipantId String
  // "scheduled" | "in_progress" | "played" | "forfeit_home" | "forfeit_away" | "cancelled"
  status            String            @default("scheduled")
  scheduledAt       DateTime?
  deadlineAt        DateTime?
  // Match qui materialise ce pairing. Null tant qu'aucun coach n'a
  // lance la partie. Ecrit par `POST /league/pairings/:id/match`
  // (L2.A.4) en meme temps que la creation du Match.
  match             Match?
  // Lot E — Snapshot des points bonus appliques au scoring de ce
  // pairing (en plus des winPoints/drawPoints standards). 0 si
  // bonusPointsConfig est null ou aucun bonus n'a matche.
  bonusPointsHome   Int               @default(0)
  bonusPointsAway   Int               @default(0)
  /// Lot E — Breakdown des regles appliquees pour audit / UI :
  /// [{ ruleId, label, side, points }]. null si aucune regle.
  bonusBreakdown    Json?
  // Lot G — feuille de match v2 (1-1, optionnelle).
  matchSheet        LeagueMatchSheet?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([roundId])
  @@index([status])
  @@index([deadlineAt, status])
  @@index([homeParticipantId])
  @@index([awayParticipantId])
}

/// Lot G — Feuille de match collaborative (saisie joueurs + validation
/// commissaire). 1-1 avec un LeaguePairing.
///
/// Workflow `status` :
///   draft            -> en cours de saisie (avant soumission)
///   submitted_home   -> coach domicile a valide sa saisie
///   submitted_away   -> coach visiteur a valide sa saisie
///   both_submitted   -> les 2 ont valide (alerte commissaire)
///   validated        -> commissaire a valide (effets appliques)
///   invalidated      -> annulee apres validation (fenetre de correction)
///
/// Les scores et la liste des blesses sont DERIVES des events
/// (`LeagueMatchEvent`) par le summarizer pur ; ils sont aussi
/// snapshotes ici a la validation pour audit + lecture rapide.
model LeagueMatchSheet {
  id        String        @id @default(cuid())
  pairing   LeaguePairing @relation(fields: [pairingId], references: [id], onDelete: Cascade)
  pairingId String        @unique
  status    String        @default("draft")

  submittedByHomeAt  DateTime?
  submittedByAwayAt  DateTime?
  validatedAt        DateTime?
  validatedById      String?
  invalidatedAt      DateTime?
  invalidationReason String?

  // ── Avant-match ──
  /// Table meteo utilisee (ex: "classique"). Distincte de la meteo initiale.
  weatherTable    String?
  /// Meteo initiale tiree (ex: "perfect").
  weather         String?
  popularityHome  Int?
  popularityAway  Int?
  /// Cote ayant declare forfait : "home" | "away" | null (pas de forfait).
  forfeitSide     String?
  /// Coups de pouce (inducements) selectionnes : [{ id, name, cost, qty }].
  inducementsHome Json?
  inducementsAway Json?
  /// Prieres de Nuffle : [{ playerId, effect, sppBonus }].
  prayersHome     Json?
  prayersAway     Json?

  // ── Score derive des events (snapshot a la validation) ──
  scoreHome Int @default(0)
  scoreAway Int @default(0)

  // ── Apres-match (snapshot, editable commissaire) ──
  /// Gain de tresorerie calcule (auto). Override possible via *Manual.
  winningsHome           Int   @default(0)
  winningsAway           Int   @default(0)
  winningsHomeManual     Int?
  winningsAwayManual     Int?
  dedicatedFansDeltaHome Int?
  dedicatedFansDeltaAway Int?
  /// Bonus au classement accorde par le commissaire (points en plus).
  rankingBonusHome       Int?
  rankingBonusAway       Int?
  /// SPP bonus "accorde par Nuffle" par joueur : [{ playerId, spp }].
  sppBonus               Json?
  /// Erreurs couteuses : [{ playerId?, cost, reason }].
  costlyErrorsHome       Json?
  costlyErrorsAway       Json?
  /// Joueurs du match (MVP) : [playerId].
  motmPlayerIds          Json  @default("[]")
  /// Achats post-match : [{ kind: 'player'|'reroll'|'staff', name, cost }].
  purchasesHome          Json?
  purchasesAway          Json?
  /// Licenciements de fin de match : [teamPlayerId]. Appliques (firedAt) a
  /// la validation, reversibles a l'invalidation.
  firedPlayerIds         Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events LeagueMatchEvent[]

  @@index([status])
}

/// Lot G — Evenement unitaire d'une feuille de match. Normalise pour
/// permettre l'agregation (stats joueurs, blesses, score) et l'edition
/// fine (ajout/suppression d'un event).
model LeagueMatchEvent {
  id             String           @id @default(cuid())
  matchSheet     LeagueMatchSheet @relation(fields: [matchSheetId], references: [id], onDelete: Cascade)
  matchSheetId   String
  /// 'kickoff' | 'touchdown' | 'casualty' | 'pass_complete' |
  /// 'interception' | 'aggression' | 'expulsion' | 'crowd_surge' |
  /// 'stalling' | 'other_elim'
  kind           String
  /// 'home' | 'away' — equipe a l'origine de l'event.
  team           String?
  /// Acteur (auteur de l'action), rosterId TeamPlayer.
  actorPlayerId  String?
  /// Cible (subit l'action), rosterId TeamPlayer.
  targetPlayerId String?
  /// Pour other_elim/casualty : 'block' | 'failed_dodge' | 'failed_leap'
  /// | 'failed_gfi' | 'secret_weapon' | 'crowd' | ...
  causeDetail    String?
  /// Severite de blessure : 'badly_hurt' | 'mng' | 'niggling' |
  /// 'stat_loss' | 'dead' | null.
  injurySeverity String?
  /// Donnees additionnelles libres (turn number, dice, etc.).
  meta           Json?
  occurredAt     DateTime         @default(now())

  @@index([matchSheetId, kind])
}

/// Catalogue des Règles Spéciales d'équipe (Bagarreurs Brutaux, Chantage et
/// Corruption, Favori de..., Trois-quarts à vil prix, Maîtres de la Non-vie,
/// Déferlement, Capitaine). Source : retranscription OCR officielle Saison 3.
/// Une règle spéciale est unique par (slug, ruleset). Aucune relation
/// directe avec Roster n'est créée ici : l'attribution se fait via le champ
/// libre `Roster.specialRules` (CSV de slugs) pour rester compatible avec
/// l'existant et ne pas modifier les données déjà présentes en prod.
model TeamSpecialRule {
  id            String   @id @default(cuid())
  slug          String
  ruleset       Ruleset  @default(season_3)
  nameFr        String
  nameEn        String
  description   String
  descriptionEn String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([slug, ruleset])
}

/// Catalogue des Ligues régionales (Bagarre des Terres Arides, Clash du Chaos,
/// Ligue des Royaumes Elfiques, Coupe Dé à Coudre Halfling, Super-ligue de
/// Lustrie, Classique du Vieux Monde, Spot de Sylvanie, Ligue Sylvestre,
/// Défi des Bas-fonds, Super-ligue du Bord du Monde). Source : retranscription
/// OCR officielle Saison 3. Le slug correspond à celui utilisé dans
/// `TEAM_REGIONAL_RULES` côté game-engine.
model RegionalLeague {
  id            String   @id @default(cuid())
  slug          String
  ruleset       Ruleset  @default(season_3)
  nameFr        String
  nameEn        String
  description   String
  descriptionEn String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([slug, ruleset])
}

// L2.B.1 — Sequence post-match Jeu en Ligue (Sprint Ligues v2 PR4).
//
// Une sequence par Match de ligue (matchId @unique). Cree apres la
// comptabilisation du resultat (recordLeagueMatchResult) pour
// orchestrer la phase post-match Blood Bowl :
//   - applique winnings + dedicatedFansChange sur Team.treasury /
//     Team.dedicatedFans (idempotent via `winningsApplied`)
//   - persiste les SPP gagnes (deja gere par persistMatchSPP) et
//     identifie les paliers atteints -> pendingChoices
//   - applique les permanent / lasting injuries definitives
//     (idempotent via `lastingInjuriesApplied`)
//   - se ferme avec status="completed" quand tous les pendingChoices
//     sont resolus (advancement choisi par le coach via L2.B.3)
//
// Idempotence : 1) contrainte unique matchId, 2) flags individuels
// par etape pour rejouer une sequence interrompue sans double-effet.
//
// Le JSON `pendingChoices` stocke un tableau de
//   { teamPlayerId: string, sppBeforeMatch: number, sppAfterMatch: number,
//     advancementsTaken: number, eligibleAt: number[] }
// ou `eligibleAt` est la liste des paliers SPP nouvellement franchis.
model LeaguePostMatchSequence {
  id                     String    @id @default(cuid())
  match                  Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId                String    @unique
  seasonId               String
  // "pending" | "awaiting_choices" | "completed"
  status                 String    @default("pending")
  winningsApplied        Boolean   @default(false)
  lastingInjuriesApplied Boolean   @default(false)
  advancementsResolved   Boolean   @default(false)
  treasuryDeltaA         Int       @default(0)
  treasuryDeltaB         Int       @default(0)
  fanFactorDeltaA        Int       @default(0)
  fanFactorDeltaB        Int       @default(0)
  // JSON-array : choix dappecement en attente (`PendingChoice[]`).
  // Stockage textuel pour rester portable PG <-> SQLite (et aux
  // ruleset evolutions).
  pendingChoices         String    @default("[]")
  createdAt              DateTime  @default(now())
  completedAt            DateTime?

  @@index([seasonId])
  @@index([status])
}

// L2.C.1 — Sprint Ligues v2 PR7 : awards de fin de saison.
// Snapshot persiste a la cloture de saison (status=completed). Stocke
// le tableau d'awards calcule par `services/leagueScoring.ts` pour
// servir la page recap et le badge champion sans recalculer a chaque
// vue. 1 row par saison via `seasonId @unique`.
//
// `awards` est stocke en JSON serialise (string) pour rester portable
// PG <-> SQLite et evoluer sans migration quand on ajoute une
// categorie d'award. Le service garantit la forme :
//   { championUserId, championTeamId, awards: SeasonAwardEntry[] }.
//
// `championUserId` peut etre null si la saison s'est terminee sans
// participants actifs (cas extreme : tous retires avant le dernier
// match). Le service dans ce cas ne cree pas d'award.
model LeagueSeasonAward {
  id             String       @id @default(cuid())
  season         LeagueSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  seasonId       String       @unique
  championUserId String?
  championTeamId String?
  awards         String       @default("{}")
  createdAt      DateTime     @default(now())

  @@index([championUserId])
}

/// Feedback public soumis depuis la page `/feedback`. Le formulaire est
/// accessible sans authentification : les soumissions doivent donc etre
/// protegees par un captcha (Cloudflare Turnstile) cote API et limitees
/// par un rate-limiter dedie.
///
/// `type` distingue bug / remarque / commentaire.
/// `status` suit le cycle de traitement cote admin :
///   - "new"      : juste recu, jamais consulte
///   - "read"     : consulte par un admin
///   - "resolved" : traite (corrige ou repondu)
///
/// `name` et `email` sont optionnels (RGPD : minimisation). On ne stocke
/// volontairement PAS l'IP du visiteur ; elle sert uniquement au rate-limit
/// et a la verification Turnstile, sans persistence. `userAgent` et
/// `pageUrl` aident au triage et sont tronques cote service.
model Feedback {
  id        String   @id @default(cuid())
  type      String
  name      String?
  email     String?
  subject   String
  message   String
  userAgent String?
  pageUrl   String?
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([createdAt])
}

// =============================================================
// Pro League — sprint Pro League lot 1.A.1
// =============================================================
//
// Modeles dedies a la Pro League simulee (16 equipes round-robin,
// 15 journees par saison). Distincts des modeles `League*` (ligues
// joueur-vs-joueur).
//
// Le sim-engine reste source de verite pour les *profils tactiques*
// et les *team values*. Cote DB on materialise uniquement l'etat
// observable : equipes, rosters, calendrier, scores, classements.
// Le replay binaire (events compresses) sera ajoute en 1.A.2.

/// La Pro League elle-meme. Singleton au MVP ("Old World League").
/// Le modele permet plusieurs ligues a terme (divisions, cross-leagues)
/// via le slug unique.
model ProLeague {
  id          String   @id @default(cuid())
  /// Slug stable, e.g. "old-world-league". Sert de cle naturelle
  /// pour les URLs publiques /pro-league/...
  slug        String   @unique
  name        String
  description String?
  /// Branding optionnel (logo, devise, palette). JSON pour souplesse.
  /// Exemple: { "motto": "Stand Firm", "primaryColor": "#7A1F1F" }
  branding    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teams   ProTeam[]
  seasons ProLeagueSeason[]
}

/// Une des 16 equipes Pro League (homages NFL x races BB).
/// Cf. `packages/sim-engine/src/tactics/race-profiles.ts` pour la liste
/// canonique. Le profil tactique (bashIndex, pace, etc.) reste dans le
/// code (versionne avec engineVer) ; la DB stocke seulement les meta
/// d'affichage et les pointeurs vers le sim.
model ProTeam {
  id             String    @id @default(cuid())
  league         ProLeague @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  leagueId       String
  /// Slug stable matchant `PRO_LEAGUE_TEAMS[i].id` dans race-profiles.ts.
  /// Ex: "pit-smashers", "buf-snow-ogres", "gb-cheese-halflings".
  slug           String    @unique
  city           String
  name           String
  /// Nom de race BB lisible ("Orc", "Wood Elf", "Halfling", etc.).
  race           String
  /// Inspiration NFL pour le branding/storytelling.
  nflFlavor      String?
  primaryColor   String?
  secondaryColor String?
  /// Team value de base (gold pieces). Source de verite : race-profiles.ts.
  /// Materialise ici pour lectures rapides + drift saisonnier.
  baseTv         Int       @default(1000)
  /// Meta libre (devises, headlines templates, fanbase size, etc.).
  meta           Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  roster          ProTeamRoster[]
  homeMatches     ProLeagueMatch[]     @relation("ProMatchHome")
  awayMatches     ProLeagueMatch[]     @relation("ProMatchAway")
  standings       ProLeagueStandings[]
  followers       ProSpectatorFollow[]
  survivorEntries ProSurvivorEntry[]

  @@index([leagueId])
}

/// Un joueur du roster d'une ProTeam. Couvre stats permanentes, forme
/// courante, et casualties persistantes (lot 1.E.4 etendra).
model ProTeamRoster {
  id          String   @id @default(cuid())
  team        ProTeam  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId      String
  name        String
  /// Position BB ("Lineman", "Blitzer", "Thrower", etc.).
  position    String
  /// Stats BB de base.
  ma          Int
  st          Int
  ag          Int
  /// PA optionnel (BB3 only ; nullable pour rosters Season 2).
  pa          Int?
  av          Int
  /// Skills (slugs). JSON array de strings, ex: ["block","dodge"].
  skills      Json
  /// Lot 1.E.4 — casualties persistantes.
  niggling    Int      @default(0)
  maReduction Int      @default(0)
  stReduction Int      @default(0)
  agReduction Int      @default(0)
  avReduction Int      @default(0)
  /// Status : "active" | "injured" | "dead" | "retired".
  status      String   @default("active")
  /// Forme 0-100. Updated post-match.
  form        Int      @default(50)
  /// Stats carriere (TD, casualties, MVPs). JSON pour souplesse.
  careerStats Json     @default("{}")
  /// Lot 3.C.2 — Star Player Points cumules (BB rules : TD=3, CAS=2,
  /// MVP=4, COMP=1). Sert au level-up entre matchs (table BB officielle :
  /// 6 SPP = first level, 16 = second, 31, 51, 76, 176).
  spp         Int      @default(0)
  /// Career counters individuels (cumulatifs sur la carriere du joueur
  /// chez ce ProTeam). Diversite -> JSON `careerStats` est trop opaque
  /// pour les index ; champs plats pour leaderboards rapides.
  tdCount     Int      @default(0)
  casCount    Int      @default(0)
  compCount   Int      @default(0)
  mvpCount    Int      @default(0)
  /// Lot 3.C.4 — Niveau du joueur (1=rookie, 7=legend). Computed from
  /// `spp` via la table BB (6/16/31/51/76/176). Stocke pour permettre
  /// les filtres "joueurs au-dessus de level 3" sans recompute en SQL.
  /// Update transactionnel avec append de skill via le level-up applier.
  level       Int      @default(1)
  /// Lot 3.C.5 — Team Value individuelle (gold pieces). Computed from
  /// position base cost + skill bonus (~20k par skill General). Update
  /// transactionnel par le level-up applier ; recomputable par batch
  /// via `sweepRecomputeTvs` pour les rosters legacy.
  tvCached    Int      @default(50000)
  /// Lot 4.D.1 — Stat increases gagnes via doubles roll au level-up
  /// (BB rules : 1/6 chance par advancement). Chaque +1 ajoute au TV :
  /// MA/AV = +30k, AG = +40k, PA = +20k, ST = +80k.
  maBonus     Int      @default(0)
  agBonus     Int      @default(0)
  paBonus     Int      @default(0)
  avBonus     Int      @default(0)
  stBonus     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  careerSnapshot ProPlayerCareerSnapshot?
  mvpVotes       ProPlayerOfMatchVote[]

  @@index([teamId, status])
  @@index([teamId, spp])
  @@index([teamId, tvCached])
}

/// Une saison instancie une ProLeague pour une annee donnee. engineVer
/// est gele a la creation pour garantir replay-determinisme.
model ProLeagueSeason {
  id         String    @id @default(cuid())
  league     ProLeague @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  leagueId   String
  year       Int
  /// Status : "scheduled" | "in_progress" | "completed" | "archived".
  status     String    @default("scheduled")
  /// engineVer pinne a la creation. Tous les matches de cette saison
  /// utilisent cette version pour la deterministe replay (lot 1.A.5).
  engineVer  String
  /// Lot 3.B.1 — driver de simulation par defaut pour la saison.
  /// "hybrid" = synthese archetype-vs-archetype (lot 0.A.2, default).
  /// "full"   = auto-play game-engine roster-aware (lot 3.A.2).
  /// Override possible par match via `ProLeagueMatch.driverKindOverride`.
  driverKind String    @default("hybrid")
  /// Sprint test-leagues — saison "test" cree depuis l'admin via la
  /// test-factory. `true` = la saison + tous ses matchs + standings sont
  /// invisibles cote user (filtre `isTest=false` partout cote
  /// agregateurs/hub/standings/leaderboards). Permet de generer une
  /// saison complete avec replays disponibles immediatement, isolee
  /// des donnees prod, et supprimable d'un coup avec tous ses matchs.
  /// Default false : toutes les saisons existantes restent "prod".
  isTest     Boolean   @default(false)
  /// Label libre pour les saisons test (ex: "Engine v2.1 regression").
  /// null pour les saisons prod ; visible uniquement aux admins.
  testLabel  String?
  startsAt   DateTime?
  endsAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  rounds          ProLeagueRound[]
  matches         ProLeagueMatch[]
  standings       ProLeagueStandings[]
  survivorEntries ProSurvivorEntry[]

  @@unique([leagueId, year])
  @@index([status])
  @@index([isTest])
}

/// Une journee (matchday). 16 equipes round-robin = 15 journees x 8
/// matchs/journee = 120 matches/saison.
model ProLeagueRound {
  id          String          @id @default(cuid())
  season      ProLeagueSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  seasonId    String
  /// 1..15 pour un round-robin classique.
  roundNumber Int
  /// Status : "pending" | "in_progress" | "completed".
  status      String          @default("pending")
  /// Date programmee (typiquement mardi 21h00).
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  matches         ProLeagueMatch[]
  survivorEntries ProSurvivorEntry[]

  @@unique([seasonId, roundNumber])
  @@index([status])
}

/// Un match Pro League. Le sim-engine produit un SimResult complet ;
/// on materialise ici les champs queryables (status, score, outcome,
/// counters) et on pointe vers `Replay` (lot 1.A.2) pour le payload
/// binaire compresse.
model ProLeagueMatch {
  id                  String          @id @default(cuid())
  season              ProLeagueSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  seasonId            String
  round               ProLeagueRound  @relation(fields: [roundId], references: [id], onDelete: Cascade)
  roundId             String
  homeTeam            ProTeam         @relation("ProMatchHome", fields: [homeTeamId], references: [id], onDelete: Cascade)
  homeTeamId          String
  awayTeam            ProTeam         @relation("ProMatchAway", fields: [awayTeamId], references: [id], onDelete: Cascade)
  awayTeamId          String
  /// Status : "scheduled" | "ready" | "in_progress" | "completed" | "failed".
  /// "ready" = pre-simule, en attente du broadcaster (lot 1.B.1).
  status              String          @default("scheduled")
  scheduledAt         DateTime
  simulatedAt         DateTime?
  completedAt         DateTime?
  /// Sprint 1.E.4 — flag idempotence pour le post-process casualties.
  /// Non-null = casualties déjà appliquées au roster.
  casualtiesAppliedAt DateTime?
  /// Lot 3.C.2 — flag idempotence pour le post-process SPP / progression.
  /// Non-null = SPP deja attribues aux rosters concernes.
  sppAppliedAt        DateTime?
  /// Lot 2.C.1 — sandbox flag. `true` = match lancé depuis l'admin
  /// (`POST /admin/sim/test-match`), exclu des standings/ELO/paris/
  /// wallet/leaderboards. Permet de tester un nouveau driver ou une
  /// nouvelle race-profile en prod sans polluer les compétitions.
  isTest              Boolean         @default(false)
  /// Lot 3.B.1 — override optionnel du driver de simulation pour ce match
  /// specifique. null = inherit `season.driverKind`. Sinon "hybrid" |
  /// "full". Utilise pour A/B test progressif au sein d'une saison.
  driverKindOverride  String?
  /// Seed sim-engine + engineVer pinne au moment de la simulation.
  /// Permet de rejouer le match a l'identique tant que engineVer matche.
  seed                BigInt?
  engineVer           String?
  /// Pointeur vers `Replay.matchId` (lot 1.A.2). Pas de FK ici tant que
  /// le modele Replay n'existe pas — sera converti en relation 1.A.2.
  replayId            String?         @unique
  /// Score cache pour listings rapides sans charger le replay.
  scoreHome           Int?
  scoreAway           Int?
  /// Outcome : "home" | "away" | "draw".
  outcome             String?
  /// Compteurs caches issus de MatchSummary.
  touchdownCount      Int?
  casualtyCount       Int?
  turnoverCount       Int?
  nuffleCount         Int?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  betMarkets      ProBetMarket[]
  predictionPicks ProPredictionPick[]
  mvpVotes        ProPlayerOfMatchVote[]
  fanPredictions  ProMatchPrediction[]

  @@index([seasonId, status])
  @@index([roundId])
  @@index([scheduledAt])
  @@index([homeTeamId])
  @@index([awayTeamId])
}

/// Classement par equipe / saison. Mis a jour atomiquement post-match.
model ProLeagueStandings {
  id                String          @id @default(cuid())
  season            ProLeagueSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  seasonId          String
  team              ProTeam         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId            String
  played            Int             @default(0)
  wins              Int             @default(0)
  draws             Int             @default(0)
  losses            Int             @default(0)
  /// Points BB-style : 3W / 1D / 0L. Configurable par ligue (Phase 2).
  points            Int             @default(0)
  tdFor             Int             @default(0)
  tdAgainst         Int             @default(0)
  casualtiesFor     Int             @default(0)
  casualtiesAgainst Int             @default(0)
  /// Forme (5 derniers matchs). JSON array : ["W","D","L","W","W"].
  form              Json            @default("[]")
  updatedAt         DateTime        @updatedAt

  @@unique([seasonId, teamId])
  @@index([seasonId, points, tdFor])
}

/// Replay binaire d'un ProLeagueMatch — sprint Pro League lot 1.A.2.
///
/// Stocke le tableau d'events compressé (CBOR + gzip via
/// `compressEvents` / `decompressEvents` du sim-engine) plus quelques
/// métadonnées consommables sans décompression :
///   - `durationMs` : durée totale du match (pour timeline UI)
///   - `highlights` : sous-ensemble compact d'events marquants (TD,
///     CAS, NUFFLE) pour l'UI "essentiels" sans charger le replay
///     complet ; généré au moment de la persistance par
///     `apps/server/services/replay-storage.ts` (lot 1.A.4).
///
/// 1-1 avec ProLeagueMatch : un replay par match max. La FK est
/// `ProLeagueMatch.replayId` → `Replay.matchId` (déjà unique côté
/// match). Côté Replay on stocke matchId comme @id pour garantir
/// l'unicité au niveau DB.
model Replay {
  /// PK = id du match. Garantit le 1-1 : un seul replay par match.
  matchId     String   @id
  /// Payload binaire CBOR + gzip. ~1-2 KB / match typique.
  payload     Bytes
  /// Highlights pré-extraits (TD, CAS, NUFFLE). JSON pour souplesse.
  /// Format: [{ type: "TD", at: 1500, team: "home" }, ...]
  highlights  Json     @default("[]")
  /// Durée totale du match (ms) pour timeline UI sans décodage.
  durationMs  Int
  /// Taille originale (JSON équivalent) — audit/monitoring.
  rawJsonSize Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Sprint Pro League lot 1.C.4 — Fan follow.
/// Permet à un user de suivre une ProTeam pour recevoir un newsfeed
/// personnalisé sur /pro-league/feed.
///
/// Une seule entrée par couple (userId, proTeamId) garantie par
/// l'@@unique. `since` permet de filtrer le feed à partir de la date
/// d'abonnement (rétro-coverage des matchs ne sert à rien — un fan
/// suit ce qui se passe à partir d'aujourd'hui).
model ProSpectatorFollow {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  team      ProTeam  @relation(fields: [proTeamId], references: [id], onDelete: Cascade)
  proTeamId String
  since     DateTime @default(now())
  createdAt DateTime @default(now())

  @@unique([userId, proTeamId])
  @@index([userId])
  @@index([proTeamId])
}

/// Sprint Pro League lot 1.D.1 — Wallet Crowns.
///
/// 1 wallet par user (`userId @id`). `crowns` est le solde courant
/// (cache) ; le ledger immuable est `Transaction` (historique
/// append-only). `crowns` est mis a jour atomiquement a chaque
/// debit/credit dans la meme transaction Prisma.
///
/// Sources de Crowns au MVP (cf. lot 1.D.6) :
///  - Inscription : 1000 Crowns offerts (REWARD)
///  - Login quotidien : 50 Crowns (max 1/24h, type DAILY)
///  - Gain de pari : montant net (WIN)
///  - Badge debloque : prime variable (BADGE)
/// Sortie de Crowns : pose d'un pari (BET, montant negatif).
model ProWallet {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Solde courant en Crowns. Mis a jour atomique avec chaque
  /// Transaction associee. Toujours >= 0 (les debit echouent en
  /// dessous via la contrainte service).
  crowns    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions ProTransaction[]
}

/// Sprint Pro League lot 1.D.1 — Ledger immuable des operations Crowns.
///
/// `type` distingue la nature : BET (mise sur un pari, debit), WIN
/// (gain net post-settlement, credit), REWARD (cadeau / first-time
/// bonus), DAILY (login quotidien), BADGE (recompense badge).
/// `amount` est signe : negatif pour debit, positif pour credit.
/// `ref` est optionnel et stocke un identifiant business (`betId`,
/// `badgeCode`, `marketId`) selon le type — facilite l'audit sans
/// rejoindre une autre table.
model ProTransaction {
  id        String    @id @default(cuid())
  wallet    ProWallet @relation(fields: [walletId], references: [userId], onDelete: Cascade)
  walletId  String
  type      String
  amount    Int
  /// Reference business optionnelle (betId, badgeCode, marketId, ...).
  ref       String?
  createdAt DateTime  @default(now())

  @@index([walletId, createdAt])
  @@index([type])
}

/// Sprint Pro League lot 1.D.2 — Marche de pari sur un match.
///
/// Un BetMarket regroupe les paris d'un type donne (`type`) sur un
/// match. Les cotes sont stockees dans `config` (Json) ; la forme
/// depend du type :
///   - ONE_X_TWO       : { homeOdds, drawOdds, awayOdds }
///   - OVER_UNDER_TD   : { line, overOdds, underOdds }
///   - CAS_COUNT       : { line, overOdds, underOdds }
///   - NUFFLE_OCCURS   : { yesOdds, noOdds }
///   - MVP             : { selections: [{key, label, odds}, ...] }
///
/// Les cotes sont calculees lot 1.D.3 (odds-calculator) au pre-match
/// puis mises a jour si le line-up change. Le lot 1.D.5 (settlement)
/// passe le market a `settled` et evalue les bets.
model ProBetMarket {
  id        String         @id @default(cuid())
  match     ProLeagueMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId   String
  /// 'ONE_X_TWO' | 'OVER_UNDER_TD' | 'CAS_COUNT' | 'NUFFLE_OCCURS' | 'MVP'
  type      String
  config    Json
  /// 'open' | 'closed' | 'settled'
  status    String         @default("open")
  /// Apres ce timestamp, plus aucun pari n'est accepte.
  closesAt  DateTime
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  bets       ProBet[]
  settlement ProBetSettlement?

  @@unique([matchId, type])
  @@index([status, closesAt])
}

/// Sprint Pro League lot 1.D.2 — Pari pose par un user.
///
/// La cote (`oddsAtPlace`) est figee au moment de la pose (fairness :
/// l'utilisateur sait exactement combien il peut gagner). Le `stake`
/// est en Crowns. Au settlement (lot 1.D.5), `status` passe a `won`/
/// `lost`/`void` et `payoutAmount` est rempli pour les gagnants
/// (= round(stake * oddsAtPlace)).
///
/// `clientToken` permet l'idempotence : 2 requetes POST avec le meme
/// token (par exemple un retry reseau) ne creent qu'un seul Bet.
model ProBet {
  id           String       @id @default(cuid())
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  market       ProBetMarket @relation(fields: [marketId], references: [id], onDelete: Cascade)
  marketId     String
  /// Selection serialisee selon le type de market (cf. ProBetMarket.type).
  selection    String
  stake        Int
  oddsAtPlace  Float
  /// 'pending' | 'won' | 'lost' | 'void'
  status       String       @default("pending")
  /// Gain net (round(stake * oddsAtPlace)) si won. null sinon.
  payoutAmount Int?
  /// Cle d'idempotence cote client (cuid genere au submit).
  clientToken  String       @unique
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([userId, createdAt])
  @@index([marketId, status])
  @@index([status])
}

/// Sprint Pro League lot 1.D.2 — Audit de settlement d'un market.
///
/// Cree au settlement (lot 1.D.5) ; 1-1 avec ProBetMarket via @unique.
/// `winningSelection` est la selection gagnante ("home"/"draw"/"away"
/// pour 1X2, "over"/"under" pour over/under, etc.).
/// `totalStake` / `totalPayout` / `betCount` : metriques agregees
/// utiles pour les leaderboards (1.D.8) sans rejoindre les bets.
model ProBetSettlement {
  id               String       @id @default(cuid())
  market           ProBetMarket @relation(fields: [marketId], references: [id], onDelete: Cascade)
  marketId         String       @unique
  winningSelection String
  totalStake       Int          @default(0)
  totalPayout      Int          @default(0)
  betCount         Int          @default(0)
  settledAt        DateTime     @default(now())
}

/// Sprint Pro League lot 1.D.9 — Badge debloque par un user.
///
/// Le catalogue des badges (codes + criteria) vit dans le code
/// (apps/server/src/services/pro-badges-catalogue.ts) — pas en DB.
/// La table ProUserBadge stocke uniquement les badges effectivement
/// debloques.
model ProUserBadge {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  /// Code stable du badge (ex: "oracle_of_nuffle", "first_kickoff").
  badgeCode String
  earnedAt  DateTime @default(now())
  /// Meta optionnelles pour l'audit (ex: betId qui a debloque le badge).
  meta      Json?

  @@unique([userId, badgeCode])
  @@index([badgeCode])
  @@index([userId])
}

/// Sprint Pro League lot 1.E.2 — Article de la Nuffle Gazette.
///
/// Genere quotidiennement par le service `pro-gazette-llm.ts` (lot
/// 1.E.1, LLM Claude Haiku) a partir du recap aggregator (1.E.3).
/// Stocke en DB pour permettre l'archive consultable a l'URL
/// `/nuffle-gazette/:date` (1.E.2).
///
/// `type` :
///  - MAIN  : article principal du jour (resume long, ~300 mots)
///  - BREVE : breve courte (~50-80 mots) sur une storyline secondaire
///  - EDITO : editorial signe par 1 des 3 personas
///
/// `persona` :
///  - 'cynic'           : le cynique (rumeurs, sarcasmes)
///  - 'orc_enthusiast'  : l'enthousiaste orc (hype, capslock)
///  - 'statistician'    : le statisticien (chiffres, analyses)
///
/// `relatedTeamIds` / `relatedPlayerIds` : Json arrays de slugs
/// referenced dans l'article — sert au cross-linking UI (lot 1.E.5
/// HoF, 1.C.2 team page).
model ProGazetteArticle {
  id               String   @id @default(cuid())
  /// Date d'edition (YYYY-MM-DD). Plusieurs articles par date.
  /// Index pour archive rapide.
  date             DateTime
  /// 'MAIN' | 'BREVE' | 'EDITO'
  type             String
  /// 'cynic' | 'orc_enthusiast' | 'statistician'
  /// MAIN/BREVE peuvent etre signes ou non ; EDITO l'est toujours.
  persona          String?
  title            String
  /// Markdown-friendly. Pas de HTML brut (sanitize cote rendu UI).
  body             String   @db.Text
  /// Json array de slugs ProTeam : ['buf-snow-ogres', 'kc-...'].
  relatedTeamIds   Json?
  /// Json array de roster ids ou autres ids joueur.
  relatedPlayerIds Json?
  createdAt        DateTime @default(now())

  comments ProGazetteComment[]

  @@index([date])
  @@index([type, date])
}

/// Sprint Pro League lot 1.E.5 — Hall of Fame light.
///
/// Snapshot d'un joueur immortalise. L'induction est declenchee :
///  - automatique sur status='dead' (apres casualty 'dead' du sweep
///    casualties 1.E.4) — `reason='death_in_match'`,
///  - manuelle ou cron later via criteres carriere (TDs, MVP, titre)
///    avec d'autres `reason` codes.
///
/// L'enregistrement gele les stats au moment de l'induction (le
/// roster d'origine peut disparaitre via cleanup futur). Idempotence
/// par `unique([rosterId, reason])`.
model ProHallOfFame {
  id          String                    @id @default(cuid())
  /// Lien vers le roster d'origine (peut etre supprime a terme — ne
  /// pas cascade pour preserver l'archive Hall of Fame).
  rosterId    String
  /// Slug ProTeam au moment de l'induction (cross-link UI sans join).
  teamSlug    String
  /// Nom team affiche au moment de l'induction.
  teamName    String
  /// Nom du joueur immortalise.
  playerName  String
  /// Race au moment de l'induction.
  race        String
  /// Position au moment de l'induction.
  position    String
  /// Snapshot stats au moment de l'induction.
  ma          Int
  st          Int
  ag          Int
  pa          Int?
  av          Int
  /// Snapshot skills (Json array).
  skills      Json
  /// Snapshot career stats (TDs, casualties, MVPs).
  careerStats Json
  /// Code raison de l'induction.
  /// Valeurs : 'death_in_match' | 'career_tds' | 'mvp_legend' | 'title'.
  reason      String
  /// Description humaine optionnelle (pour rendu UI).
  citation    String?
  inductedAt  DateTime                  @default(now())
  /// Sprint P (Lot P.B.2) — dedications fans payees en Crowns.
  dedications ProHallOfFameDedication[]

  @@unique([rosterId, reason])
  @@index([teamSlug])
  @@index([reason])
  @@index([inductedAt])
}

/// Sprint P (Lot P.B.2) — Dedications sur les entrees Hall of Fame.
/// Sink Crowns : un user paie 500 Crowns pour epingler un message
/// custom (max 280 chars) sur une entree HoF. 1 dedicace par user
/// par entree (unique[hallOfFameId, userId]). Sert de Crowns sink
/// pour prevenir l'hyperinflation introduite par les daily bonus +
/// gains de paris.
model ProHallOfFameDedication {
  id           String        @id @default(cuid())
  hallOfFameId String
  hallOfFame   ProHallOfFame @relation(fields: [hallOfFameId], references: [id], onDelete: Cascade)
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Texte custom max 280 chars (validation Zod cote service).
  message      String        @db.VarChar(280)
  /// Crowns debites au moment de la dedicace (500 par defaut).
  costCrowns   Int
  createdAt    DateTime      @default(now())

  @@unique([hallOfFameId, userId])
  @@index([userId])
  @@index([hallOfFameId, createdAt])
}

/// Lot P.B.2 — Tournois Pro League payants. **Sink Crowns** : un user
/// s'inscrit (entry fee 100 Crowns par defaut, configurable par
/// tournoi). Idempotent : un user ne peut s'inscrire qu'une fois par
/// tournoi (unique [tournamentId, userId]).
///
/// `status` workflow : `open` → `closed` (plus d'inscription possible)
/// → `in_progress` (matchs lances) → `completed`. Pas de cron pour le
/// moment : un admin set le status manuellement via une future UI.
///
/// `maxEntries` est optionnel ; null = pas de cap. Quand cap atteint,
/// le service refuse les inscriptions suivantes (sans changer le
/// status — l'admin decide quand fermer).
model ProTournament {
  id             String               @id @default(cuid())
  /// Slug stable URL-safe (ex: "winter-cup-2026"). Unique.
  slug           String               @unique
  name           String
  description    String?
  /// Crowns requis pour s'inscrire (debit unique au moment de l'entry).
  entryFeeCrowns Int                  @default(100)
  /// Cap optionnel d'inscriptions. null = illimite.
  maxEntries     Int?
  /// "open" | "closed" | "in_progress" | "completed".
  status         String               @default("open")
  /// Dates indicatives (UI). Pas de logique business derivee.
  startsAt       DateTime?
  endsAt         DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  entries        ProTournamentEntry[]

  @@index([status, createdAt])
}

/// Lot P.B.2 — Entry payee d'un user dans un ProTournament. Unique
/// (tournamentId, userId) garantit qu'un user ne paie qu'une fois.
/// `paidCrowns` snapshot du fee au moment de l'entry (resilient si
/// l'admin modifie le fee plus tard).
model ProTournamentEntry {
  id           String        @id @default(cuid())
  tournamentId String
  tournament   ProTournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  paidCrowns   Int
  createdAt    DateTime      @default(now())

  @@unique([tournamentId, userId])
  @@index([userId])
  @@index([tournamentId, createdAt])
}

/// S27.6 — Trace immuable des actions admin (compliance + tracabilite).
///
/// Une entree par mutation effectuee par un compte admin sur les
/// routes `/admin/*`. Les lectures (GET) ne sont pas tracees pour
/// eviter de saturer la table.
///
/// `userId` peut etre null si l'action est un job systeme (cron,
/// migration script). Sinon il pointe sur l'admin qui a declenche
/// l'action.
model AuditLog {
  id        String   @id @default(cuid())
  /// Admin qui a declenche l'action (null si systeme).
  userId    String?
  /// Slug d'action ("user.role.update", "match.delete", etc.).
  action    String
  /// Type d'entite cible ("User", "Match", "Skill", ...).
  entity    String
  /// Identifiant de l'entite cible (cuid ou null pour les batchs).
  entityId  String?
  /// Snapshot avant mutation (Json libre, null pour les creations).
  oldValue  Json?
  /// Snapshot apres mutation (Json libre, null pour les suppressions).
  newValue  Json?
  /// Adresse IP source (best-effort, peut etre absente derriere un
  /// proxy mal configure).
  ipAddress String?
  /// User-Agent source (debug + forensic).
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([entity, entityId])
  @@index([action])
  @@index([createdAt])
}

/// Lot 3.B.2 — Snapshot d'une comparaison hybrid vs full driver.
///
/// Une entree par exécution du comparator (script CLI ou route admin
/// `POST /admin/sim/comparison`). Permet :
///   - de tracker la dérive entre les deux drivers à travers les
///     versions d'engineVer (avant/apres rebalance, post bugfix, etc.)
///   - de fournir un input à un dashboard Grafana (jointure sur
///     engineVer + race pairing pour graph time-series)
///   - de detecter une regression brutale du full driver (ex: outcome
///     flip rate > 10% sur un pairing qui avait 2%) avant prod.
///
/// Les runs CLI ne persistent PAS automatiquement — seul `POST
/// /admin/sim/comparison` ecrit dans cette table. Les Prometheus
/// gauges `nuffle_engine_compare_*` sont mises a jour par le meme
/// service au moment de la persistence.
model EngineComparison {
  id                  String   @id @default(cuid())
  /// engineVer pour lequel la comparaison a ete lancee (les deux
  /// drivers utilisent forcement la meme version a un instant T).
  engineVer           String
  /// Slug de l'equipe a domicile (ex: 'pit-smashers'). Pas de FK car
  /// le comparator peut etre lance sur des profils PRO_LEAGUE_TEAMS qui
  /// existent uniquement dans le code, pas en DB (ex: bench dev).
  homeTeamId          String
  /// Slug de l'equipe a l'exterieur.
  awayTeamId          String
  /// Nombre de matchs simulés dans cette comparaison.
  matches             Int
  /// Seed offset utilisé (premier seed = `seedOffset`, dernier = `seedOffset + matches - 1`).
  seedOffset          Int
  /// scoreTotal — moyenne du delta absolu home+away.
  meanScoreDelta      Float
  /// scoreTotal — p95 du delta absolu (Prometheus gauge).
  p95ScoreDelta       Float
  /// scoreTotal — max du delta absolu (worst-case audit).
  maxScoreDelta       Float
  /// turnoverCount — moyenne du delta.
  meanTurnoverDelta   Float
  /// touchdownCount — moyenne du delta.
  meanTouchdownDelta  Float
  /// casualtyCount — moyenne du delta.
  meanCasualtyDelta   Float
  /// Nombre de matchs avec outcome flip (home<->away ou draw shift).
  outcomeFlippedCount Int
  /// Pct (0..1) de matchs avec scoreTotal>0 OR outcomeChanged.
  divergedPct         Float
  /// Source d'invocation : 'cli' | 'admin' (provenance audit).
  source              String   @default("admin")
  createdAt           DateTime @default(now())

  @@index([engineVer, createdAt])
  @@index([homeTeamId, awayTeamId, createdAt])
}

/// Sprint Q lot Q.D.1 — Mini-ligue de pronostics privee.
///
/// Un user cree une ligue avec un `name` et un `joinCode` unique de
/// 8 chars. Il devient automatiquement membre. D'autres users
/// rejoignent via le code. Le score est calcule a partir des picks
/// `ProPredictionPick` (1 point par pick correct).
model ProPredictionLeague {
  id        String   @id @default(cuid())
  name      String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId   String
  /// Code de jonction unique de 8 chars (ex: "ABC12XYZ"). Case-sensitive
  /// (uppercase pour faciliter le partage oral).
  joinCode  String   @unique
  /// `true` (default) = privee, accessible via code uniquement.
  /// `false` = publique, listee sur une page de decouverte (future).
  isPrivate Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members ProPredictionLeagueMember[]
  picks   ProPredictionPick[]

  @@index([ownerId])
}

/// Sprint Q lot Q.D.1 — Membre d'une ProPredictionLeague.
///
/// Unicite (leagueId, userId) : un user ne peut etre membre qu'une
/// fois par ligue. La presence du record = appartenance ; le retrait
/// efface le record.
model ProPredictionLeagueMember {
  id       String              @id @default(cuid())
  league   ProPredictionLeague @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  leagueId String
  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  joinedAt DateTime            @default(now())

  @@unique([leagueId, userId])
  @@index([userId])
}

/// Sprint Q lot Q.D.1 — Pick d'un user sur un match dans le contexte
/// d'une ligue de pronostics.
///
/// `selection` : "home" | "draw" | "away" (winner pick MVP). Une
/// version future pourra etendre a "exact_score" (string libre type
/// "3-1") via un champ `selectionType` mais pour le MVP on reste
/// simple.
///
/// Unicite (leagueId, userId, matchId) : un user ne peut soumettre
/// qu'un pick par (ligue, match). Update via upsert tant que le match
/// est `scheduled` ; verrouille apres `kickoff` (verifie au niveau
/// service).
model ProPredictionPick {
  id        String              @id @default(cuid())
  league    ProPredictionLeague @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  leagueId  String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  match     ProLeagueMatch      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId   String
  /// "home" | "draw" | "away".
  selection String
  /// Resultat (`null` tant que match pas complete). Set au settlement :
  /// "home" | "draw" | "away" base sur scoreHome vs scoreAway du match.
  result    String?
  /// `true` si selection == result. Set au settlement.
  correct   Boolean?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([leagueId, userId, matchId])
  @@index([leagueId, matchId])
  @@index([userId, createdAt])
}

/// Sprint Q lot Q.D.2 — Survivor Pick'em hebdo.
///
/// Concept BB Survivor :
///   - Une saison Pro League en cours fait office de "ligue survivor".
///   - Chaque round = une semaine de survivor.
///   - L'utilisateur pique 1 equipe parmi celles qui jouent ce round
///     avant le kickoff (round.status = "pending").
///   - Si l'equipe gagne son match → status="alive".
///   - Si elle perd ou egalise → status="eliminated".
///   - Une equipe ne peut pas etre re-piquee dans la meme saison (unique
///     `seasonId + userId + pickedTeamId`).
///   - Un user peut piquer 1 fois par round (unique `seasonId + userId +
///     roundId`).
///   - Le dernier alive (ou tous les alive a la fin) gagne.
model ProSurvivorEntry {
  id           String          @id @default(cuid())
  season       ProLeagueSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  seasonId     String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  round        ProLeagueRound  @relation(fields: [roundId], references: [id], onDelete: Cascade)
  roundId      String
  /// Mirroir de `round.roundNumber` materialise pour le tri/affichage.
  weekN        Int
  pickedTeam   ProTeam         @relation(fields: [pickedTeamId], references: [id], onDelete: Cascade)
  pickedTeamId String
  /// "pending" tant que le round n'est pas completed. Apres : "alive"
  /// (equipe a gagne) ou "eliminated" (perdu ou nul).
  status       String          @default("pending")
  /// Resultat du match correspondant : "win" | "loss" | "draw". Set au
  /// settlement (en meme temps que `status`).
  result       String?
  /// Reference au match settle (pour faciliter le replay UI).
  matchId      String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  /// 1 pick par (user, round) — un user ne peut piquer qu'une fois
  /// par semaine.
  @@unique([seasonId, userId, roundId])
  /// Pas de re-pick de la meme equipe dans la meme saison.
  @@unique([seasonId, userId, pickedTeamId])
  @@index([seasonId, weekN])
  @@index([userId, seasonId])
  @@index([status])
}

/// Sprint Q lot Q.A.1 — Snapshot agrege des stats career d'un joueur.
///
/// Materialise par un compute "best-effort lazy" : computes lorsque la
/// route /api/pro-league/players/:id/career est appelee et que le
/// snapshot existant est obsolete (recomputedAt > STALE_WINDOW). Permet
/// d'eviter de re-scanner toute l'histoire des matchs a chaque appel.
///
/// Les fields a vraie valeur ajoutee (vs simples lookups sur
/// ProTeamRoster) :
///   - bestMatchId / worstMatchId (max/min totalSpp du match)
///   - topNemesisTeamId / topVictoryTeamId (top opponent par loss / win)
///   - currentStreak : longueur du streak en cours (kind + length)
///   - matchesPlayed : count des matchs avec status completed
model ProPlayerCareerSnapshot {
  id                 String        @id @default(cuid())
  player             ProTeamRoster @relation(fields: [playerId], references: [id], onDelete: Cascade)
  playerId           String        @unique
  matchesPlayed      Int           @default(0)
  tdTotal            Int           @default(0)
  casTotal           Int           @default(0)
  compTotal          Int           @default(0)
  mvpTotal           Int           @default(0)
  sppTotal           Int           @default(0)
  bestMatchId        String?
  bestMatchSpp       Int?
  worstMatchId       String?
  worstMatchSpp      Int?
  topNemesisTeamId   String?
  topVictoryTeamId   String?
  /// Lot Q.A.2 — top 5 matches par totalSpp (desc). Stocke en JSON
  /// pour eviter une jointure : `[{ matchId, sppTotal }, ...]`.
  topMatchesJson     Json?
  /// Lot Q.A.2 — top 3 teams nemesis (most loss vs). JSON array de
  /// team ids ordonne par count desc.
  topNemesisIdsJson  Json?
  /// Lot Q.A.2 — top 3 teams souffre-douleur (most win vs).
  topVictoryIdsJson  Json?
  /// Lot Q.A.2 — count casualties subies (CASUALTY events ou le
  /// playerId == this.player.id).
  casualtiesReceived Int           @default(0)
  /// Lot Q.A.2 — count casualties infligees (alias semantique de
  /// `casTotal` pour clarte UI).
  casualtiesDealt    Int           @default(0)
  /// "win" | "loss" | "draw" | "none" — direction du streak en cours.
  streakKind         String        @default("none")
  /// Longueur du streak (>= 0).
  streakLength       Int           @default(0)
  /// Timestamp du dernier compute. Sert au staleness check.
  recomputedAt       DateTime      @default(now())
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([recomputedAt])
}

/// Sprint Q lot Q.B.1 — Vote MVP (Player of the Match) post-match.
///
/// Un user vote pour 1 joueur sur 1 match. La window est ouverte 24h
/// apres `match.completedAt` ; verifie cote service au submitVote.
/// Le winner du tally final peut etre award via un endpoint admin
/// (closeMvpVote) ou un cron post-window.
model ProPlayerOfMatchVote {
  id            String         @id @default(cuid())
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  match         ProLeagueMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId       String
  votedRoster   ProTeamRoster  @relation(fields: [votedRosterId], references: [id], onDelete: Cascade)
  votedRosterId String
  createdAt     DateTime       @default(now())

  /// 1 vote par user par match.
  @@unique([userId, matchId])
  @@index([matchId, votedRosterId])
  @@index([votedRosterId, createdAt])
}

/// Sprint Q lot Q.B.2 — Commentaires sur un article Gazette.
///
/// Moderation simple :
///   - `deletedAt` set par admin ou auteur → soft delete (masque pour
///     tous sauf admin si filter actif).
///   - `flaggedAt` + `flagReason` set par auto-blocklist a la creation,
///     ou par admin/user "report". Si flagged → hiddenForOthers=true
///     (masque pour tous sauf auteur et admin).
///
/// Pour le MVP, pas de Perspective API : blocklist hardcodee dans le
/// service. Etend en lot subsequent si volume justifie.
model ProGazetteComment {
  id         String            @id @default(cuid())
  article    ProGazetteArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId  String
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  /// Max 500 chars (verifie cote service).
  body       String            @db.Text
  /// Soft delete : si set, le commentaire n'est plus visible.
  deletedAt  DateTime?
  /// Si set, commentaire flagged (auto-blocklist ou report). Masque
  /// pour les autres users.
  flaggedAt  DateTime?
  /// Raison du flag (ex: "blocklist:slur", "admin:spam", "user:report").
  flagReason String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([articleId, createdAt])
  @@index([userId, createdAt])
  @@index([flaggedAt])
  @@index([deletedAt])
}

/// Sprint Q lot Q.B.3 — Prediction publique d'un fan pre-match.
///
/// Un user poste une prediction texte (max 200 chars) avant le match.
/// Apres completion, l'heuristique scoring evalue chaque prediction :
///   - winnerMatched: contient mention de l'equipe gagnante (slug ou
///     nom, case-insensitive)
///   - scoreMatched: contient un score "X-Y" coherent avec le score
///     reel (ou un proche, tolerance ±1 TD)
/// Si winnerMatched ET scoreMatched → score='perfect'
///   sinon si winnerMatched → 'winner'
///   sinon → 'wrong'
/// Le badge 'seer' est attribue (en lot subsequent) aux users qui
/// accumulent N predictions 'perfect'/semaine.
model ProMatchPrediction {
  id        String         @id @default(cuid())
  match     ProLeagueMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId   String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  /// Texte libre, max 200 chars.
  body      String
  /// "perfect" | "winner" | "wrong" — null tant que match pas settle.
  score     String?
  /// Settled timestamp.
  scoredAt  DateTime?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  /// 1 prediction par user par match.
  @@unique([matchId, userId])
  @@index([matchId, createdAt])
  @@index([userId, score])
  /// Audit round 10 (MEDIUM/perf) : settlePredictions filtre
  /// `{ matchId, score: null }`. Sans index dedie, Postgres scanne
  /// toutes les rows pour ce matchId.
  @@index([matchId, score])
  /// Round 10 : getSeerLeaderboard filtre
  /// `{ score: { not: null }, scoredAt: { gte: ... } }`.
  @@index([score, scoredAt])
}

/// Articles de blog rédigés depuis l'admin via éditeur WYSIWYG.
/// HTML stocké dans `contentHtml` après sanitization côté serveur.
/// Statut "draft" invisible côté public ; "published" expose l'article.
/// publishedAt = première date de publication (set quand status passe à
/// published). Réversible : repasser en draft conserve publishedAt pour
/// l'historique mais cache l'article.
model BlogPost {
  id            String    @id @default(cuid())
  /// Slug URL-safe unique (ex: "lancement-saison-2025"). Sert de route
  /// publique `/blog/<slug>`.
  slug          String    @unique
  title         String
  /// Résumé court (max ~280 chars) pour les listings et meta description.
  excerpt       String?
  /// HTML sanitizé côté serveur via sanitize-html (allowlist stricte).
  contentHtml   String
  /// URL absolue ou path `/images/...` pour la cover. Optionnelle.
  coverImageUrl String?
  /// "draft" | "published". Seuls les "published" sont exposés publiquement.
  status        String    @default("draft")
  /// Date de publication initiale (set côté serveur quand status devient
  /// "published" pour la première fois). Sert au tri public et à l'OG date.
  publishedAt   DateTime?
  /// Auteur (lien vers User pour audit + affichage). Préservé même si user
  /// supprimé : SetNull plutôt que Cascade.
  author        User?     @relation("BlogPostAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  authorId      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status, publishedAt])
  @@index([authorId])
}

// ─────────────────────────────────────────────────────────────────────
// NFL Fantasy module — Phase 1.E
// Source : docs/nfl-fantasy/10-architecture.md § "Schéma Prisma"
// Décisions appliquées :
//   - Q5 : race fixe par équipe (NflPlayer.bbRace dérivé via NflTeam,
//          pas de champ archetype en V1)
//   - Q6 : silos séparés Pro League — modèles NflXxx indépendants
//          des Pro* / Match (pas de FK cross-module)
//   - Q8 : pseudonymisation full + flag DB realNameDisplay sur NflPlayer
// ─────────────────────────────────────────────────────────────────────

model NflSeason {
  /// ID de saison NFL au format "{yearStart}" (ex: "2025" pour la saison 2025-26).
  id        String   @id
  startDate DateTime
  endDate   DateTime
  /// "upcoming" | "in_progress" | "completed"
  status    String

  weeks   NflWeek[]
  games   NflGame[]
  rosters NflRosterSnapshot[]
}

model NflWeek {
  /// ID au format "{seasonId}:W{weekNumber}" (ex: "2025:W10").
  id         String   @id
  seasonId   String
  /// 1-18 regular season + 19-22 post-season (Wildcard=19, Div=20, Conf=21, SB=22).
  /// Note POC: nflverse utilise 19-22 continu, ESPN reset à 1 en post-season
  /// (Wildcard=1, SB=5, Pro Bowl=4 skip). Mapping géré dans nfl-ingest.ts.
  weekNumber Int
  startDate  DateTime
  endDate    DateTime
  isPlayoffs Boolean  @default(false)

  season NflSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  games  NflGame[]

  @@unique([seasonId, weekNumber])
  @@index([seasonId, weekNumber])
}

model NflTeam {
  /// Code NFL standard (ex: "KC", "MIA", "NYG"). Aligné avec
  /// data/teams.json de @bb/nfl-mapper et avec le champ `team` du CSV nflverse.
  code      String @id
  /// Ville pseudonymisée (cf. Q8 + docs/nfl-fantasy/01-legal.md).
  /// Ex: "Kansas City", "Los Angeles (R)", "New York (G)".
  city      String
  /// Race BB attribuée (Q5 fixe par équipe). Valeurs alignées avec BbRace
  /// de @bb/nfl-mapper : Skaven | WoodElf | Orc | Human | Norse | Dwarf |
  /// Khorne | Necromantic.
  bbRace    String
  /// Label public utilisé en UI (ex: "Kansas City Skaven").
  raceLabel String

  homeGames NflGame[]   @relation("NflHomeTeam")
  awayGames NflGame[]   @relation("NflAwayTeam")
  players   NflPlayer[]
}

model NflPlayer {
  /// ID stable joueur. Source de vérité = nflverse `player_id` (alias
  /// gsis_id, format "00-0033873"). Standard NFL officiel.
  id String @id

  /// PRIVÉ — jamais exposé publiquement en V1 (Q8 pseudonymisation full).
  /// Conservé pour mapping interne et upgrade futur si licence NIL/NFLPA.
  realName String

  /// Pseudonyme public (cf. @bb/nfl-mapper generatePseudonym).
  /// Ex: "Le Sidearm Wizard de Kansas City, #15".
  pseudonym String

  /// Q8 flag : false en V1 (pseudo full). Bascule à true par joueur
  /// uniquement si licence individuelle obtenue (deal NIL ou NFLPA GLA).
  /// Permet le pivot futur sans migration lourde.
  realNameDisplay Boolean @default(false)

  /// Code équipe NFL actuel (peut être null si FA / retired).
  teamCode     String?
  jerseyNumber Int?
  /// Position NFL d'origine (QB/RB/WR/TE/OL/DT/DE/LB/CB/S/...).
  nflPosition  String
  /// Position BB dérivée via getBbPosition(nflPosition, race).
  bbPosition   String
  /// Stats BB { ma, st, ag, pa, av }. Format JSON pour flexibilité V2.
  bbStats      Json
  /// Skills BB (string[]). Format JSON.
  bbSkills     Json
  /// "active" | "ir" | "retired" | "suspended"
  status       String    @default("active")
  retiredAt    DateTime?

  /// Bio remontee via ingestNflverseRosters (Phase 5.A). Tous
  /// optionnels — pas tous les joueurs ont la donnee.
  heightInches Int?
  weightLbs    Int?
  birthDate    DateTime?
  college      String?
  /// URL de la headshot officielle nflverse (CDN GitHub). Stable.
  headshotUrl  String?
  /// Annee de draft (ex: 2017). null si UDFA.
  draftYear    Int?
  /// Round de draft (1-7). null si UDFA / inconnu.
  draftRound   Int?
  /// Pick number overall (1-262). null si UDFA / inconnu.
  draftPick    Int?
  /// Equipe qui a drafte (peut differer de teamCode actuel).
  draftClub    String?
  /// Premiere annee NFL (rookie_year nflverse). null si inconnu.
  rookieYear   Int?
  /// Annees d'experience NFL au moment du roster snapshot.
  yearsExp     Int?

  /// V3 cote dynamique (MPG-style). Mise a jour apres chaque settle
  /// week par computeDynamicValue. C'est la valeur de marche actuelle
  /// du joueur, utilisee comme :
  ///   - prix de base pour les nouvelles encheres mercato
  ///   - credit budget lors d'une revente (sellPlayer)
  /// Initialisation : 50 TV (plancher) jusqu'a la 1ere recompute.
  currentValue      Int       @default(50)
  /// Cote precedente (avant le dernier recompute) pour calculer le
  /// delta affiche cote UI (badge up/down). Snapshot detaille =
  /// NflPlayerValueSnapshot.
  previousValue     Int       @default(50)
  /// Timestamp du dernier recompute. null si jamais recompute (joueur
  /// rookie / fresh ingest).
  valueRecomputedAt DateTime?

  team           NflTeam?                 @relation(fields: [teamCode], references: [code], onDelete: SetNull)
  gameStats      NflGameStat[]
  valueSnapshots NflPlayerValueSnapshot[]

  @@index([teamCode, bbPosition])
  @@index([status])
}

/// V3 historique des cotes par week. Inserted par
/// recomputeAllPlayerValues apres chaque settle. Permet de tracer
/// l'evolution sur une saison et d'afficher des graphs UI.
model NflPlayerValueSnapshot {
  id            String   @id @default(cuid())
  playerId      String
  /// Format "{year}:W{n}" (FK logique vers NflWeek).
  weekId        String
  /// Saison pour faciliter les queries par saison sans rejoindre week.
  seasonId      String
  value         Int
  /// SPP cumules au moment du snapshot (debug / explication UI).
  sppAtSnapshot Int      @default(0)
  createdAt     DateTime @default(now())

  player NflPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, weekId])
  @@index([seasonId, playerId])
  @@index([weekId])
}

model NflGame {
  /// nflverse game_id.
  id        String   @id
  seasonId  String
  weekId    String
  homeTeam  String
  awayTeam  String
  homeScore Int?
  awayScore Int?
  kickoffAt DateTime
  /// "scheduled" | "in_progress" | "final"
  status    String

  season NflSeason     @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  week   NflWeek       @relation(fields: [weekId], references: [id], onDelete: Cascade)
  home   NflTeam       @relation("NflHomeTeam", fields: [homeTeam], references: [code])
  away   NflTeam       @relation("NflAwayTeam", fields: [awayTeam], references: [code])
  stats  NflGameStat[]

  @@index([weekId])
  @@index([seasonId, kickoffAt])
}

model NflGameStat {
  id String @id @default(cuid())

  gameId   String
  playerId String

  /// Stats brutes (toutes colonnes nflverse pertinentes). Format JSON pour
  /// supporter les évolutions du payload upstream.
  rawStats Json

  /// SPP calculé via @bb/nfl-mapper computeSpp(). Null si pas encore settle.
  computedSpp Int?

  /// Détail des events SPP (SppEvent[]). JSON pour audit Gazette.
  sppBreakdown Json?

  /// "nflverse" | "espn" | "manual"
  ingestSource String
  ingestedAt   DateTime @default(now())

  game   NflGame   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  player NflPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([gameId, playerId])
  @@index([playerId])
}

model NflRosterSnapshot {
  id         String   @id @default(cuid())
  seasonId   String
  teamCode   String
  snapshotAt DateTime @default(now())
  /// Liste joueurs au format JSON : [{ id, jersey, pos, bbPos, ... }]
  roster     Json

  season NflSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@index([seasonId, teamCode])
}

model NflIngestRun {
  id          String    @id @default(cuid())
  /// "nflverse" | "espn"
  source      String
  weekId      String?
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  /// "success" | "partial" | "failed"
  status      String
  /// { gamesUpdated, playersUpdated, errors: [...] }
  result      Json

  @@index([source, startedAt])
}

// ─── Fantasy game cote user (Phase 2.C) ─────────────────────────────

model NflFantasyLeague {
  id          String   @id @default(cuid())
  /// Nom de la league, 3-50 caracteres (validation cote service).
  name        String
  /// User.id du proprietaire (cf. memo : pas de FK explicite pour
  /// eviter de modifier le modele User).
  ownerId     String
  /// Taille cible. Default Q2 = 10 ; range 2-16.
  size        Int      @default(10)
  /// "public" | "private". Default Q1 = "private" (invite-only).
  type        String   @default("private")
  /// "snake" | "auction" | "free". V2 mercato : valeur conservee en DB
  /// pour future extension snake interactif, mais l'UI publique ne
  /// propose plus que le mode unique "auction" (mercato a encheres
  /// secretes asynchrones, MPG-style).
  draftMode   String   @default("auction")
  /// "draft" | "in_progress" | "completed"
  status      String   @default("draft")
  /// FK logique vers NflSeason.id (string, pas de FK relationnelle).
  seasonId    String
  /// Code court (8 chars upper alphanum) pour les private leagues.
  /// null pour les leagues publiques.
  inviteCode  String?  @unique
  /// Budget initial alloue a chaque entry pour le mercato V2. Default
  /// 5000 TV (~10-15 joueurs, mix stars + rookies selon les prix).
  draftBudget Int      @default(5000)
  /// FK logique vers NflFantasySeasonCycle.id. Nullable pour
  /// retro-compat avec les championnats crees avant l'introduction des
  /// cycles ; pour les nouveaux championnats, la valeur est exigee par
  /// le service createLeague (snap-to-next-window).
  cycleId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entries       NflFantasyEntry[]
  matchups      NflFantasyMatchup[]
  draftSessions NflFantasyDraftSession[]
  cycle         NflFantasySeasonCycle?   @relation(fields: [cycleId], references: [id])

  @@index([ownerId])
  @@index([status, type])
  @@index([seasonId])
  @@index([cycleId])
}

/// Decoupage de la saison NFL en "mini-saisons" pour les championnats
/// Nuffle Coach. Une saison NFL (18 semaines reg + 4 playoffs) est
/// divisee en 3 cycles reguliers de 6 semaines + 1 cycle playoffs de
/// 4 semaines. Chaque championnat est rattache a un cycle, ce qui
/// permet :
///   - Engagement court (6 semaines) plutot que 18.
///   - Multi-cycle par saison : un coach peut jouer 3 championnats
///     dans une meme annee NFL.
///   - Snap-to-next-window pour la creation tardive : on refuse de
///     creer un championnat dans un cycle deja demarre, et on
///     redirige vers le cycle suivant.
model NflFantasySeasonCycle {
  id          String   @id @default(cuid())
  /// FK logique vers NflSeason.id (ex: "2025").
  seasonId    String
  /// Position du cycle dans la saison (1, 2, 3, 4).
  cycleNumber Int
  /// "regular" | "playoffs". Determine le scoring (multipliers
  /// playoffs futurs) et la duree (6 semaines vs 4).
  cycleType   String   @default("regular")
  /// Label public ("Conference 1", "Playoffs", etc.).
  label       String
  /// Premiere NflWeek.weekNumber incluse (ex: 1, 7, 13, 19).
  startWeek   Int
  /// Derniere NflWeek.weekNumber incluse (ex: 6, 12, 18, 22).
  endWeek     Int
  createdAt   DateTime @default(now())

  leagues NflFantasyLeague[]

  @@unique([seasonId, cycleNumber])
  @@index([seasonId])
}

model NflFantasyEntry {
  id              String   @id @default(cuid())
  leagueId        String
  /// User.id du membre.
  userId          String
  /// Nom d'equipe choisi par l'user, 3-50 char. Unique par league.
  teamName        String
  /// Race BB optionnelle (V2 variant "Pure BB"). null en V1 (Q5 = race
  /// fixe par equipe via NflPlayer.teamCode -> NflTeam.bbRace).
  bbRace          String?
  /// Style de jeu choisi a la creation (modifiable tant que la semaine
  /// courante n'est pas lockee). Definit les plafonds de composition de
  /// lineup par archetype (PLAY_STYLE_CAPS dans @bb/nfl-mapper) :
  /// "balanced" | "offensive" | "air_raid" | "defensive". Default
  /// "balanced". Plafonds = max only sur les postes offensifs premium ;
  /// les fillers (lineman/defense) restent illimites → 11 titulaires
  /// toujours faisables meme avec des blessures.
  playStyle       String   @default("balanced")
  /// Total Team Value (somme des tvCost sur les NflFantasyRoster).
  /// Mis a jour par le service mercato Phase 2.F.
  totalTV         Int      @default(0)
  /// Budget restant pour le mercato V2. Initialise a
  /// `NflFantasyLeague.draftBudget` lors de la creation de l'entry,
  /// decremente a chaque enchere remportee a la resolution d'une session.
  budgetRemaining Int      @default(5000)
  joinedAt        DateTime @default(now())

  league      NflFantasyLeague         @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  roster      NflFantasyRoster[]
  lineups     NflFantasyLineup[]
  rerolls     NflFantasyReroll[]
  inducements NflFantasyInducement[]
  bids        NflFantasyDraftBid[]
  careers     NflFantasyPlayerCareer[]

  @@unique([leagueId, userId])
  @@unique([leagueId, teamName])
  @@index([userId])
}

// ─── Roster + lineup (Phase 2.D) ──────────────────────────────────

model NflFantasyRoster {
  id          String   @id @default(cuid())
  entryId     String
  /// NflPlayer.id (string, FK logique seulement).
  playerId    String
  /// "draft" | "mercato" | "trade" | "free_agent"
  acquiredVia String   @default("draft")
  acquiredAt  DateTime @default(now())
  /// Team Value de ce joueur quand acquis (frozen). Permet de tracker
  /// l'evolution sans recalculer la valeur courante.
  tvCost      Int      @default(0)

  entry NflFantasyEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@unique([entryId, playerId])
  @@index([playerId])
}

/// Carriere d'un NflPlayer au sein d'une NflFantasyEntry. Agrege les
/// SPP gagnes au fil des weeks (incrementes par settleNflFantasyWeek)
/// et permet de depenser ces SPP pour debloquer des skills BB
/// supplementaires. La carriere est portee par le couple
/// (entryId, playerId) — un meme joueur a des progressions
/// independantes selon la ligue ou il est drafte.
model NflFantasyPlayerCareer {
  id             String   @id @default(cuid())
  entryId        String
  /// NflPlayer.id (FK logique alignee sur NflFantasyRoster).
  playerId       String
  /// SPP cumules sur toute la saison fantasy (jamais decrement).
  sppCareer      Int      @default(0)
  /// SPP deja depenses en skill unlocks.
  sppSpent       Int      @default(0)
  /// Skills BB unlockes via depense SPP (string[] de slugs).
  skillsUnlocked Json     @default("[]")
  /// Reserve future amelioration de stats. {} initialement.
  statsBonus     Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  entry NflFantasyEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@unique([entryId, playerId])
  @@index([playerId])
}

model NflFantasyLineup {
  id            String    @id @default(cuid())
  entryId       String
  /// FK logique vers NflWeek.id (format "{year}:W{n}").
  weekId        String
  /// playerId du captain (×1.5). Doit etre dans starters.
  captainId     String?
  /// playerId du vice-captain (×1.2). Doit etre dans starters,
  /// different du captain.
  viceCaptainId String?
  lockedAt      DateTime?
  /// Total SPP apres settlement Phase 2.E. Null tant que pas settle.
  totalSpp      Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  entry    NflFantasyEntry           @relation(fields: [entryId], references: [id], onDelete: Cascade)
  starters NflFantasyLineupStarter[]

  @@unique([entryId, weekId])
  @@index([weekId])
}

// ─── Mercato : rerolls + inducements (Phase 2.F) ────────────────

model NflFantasyReroll {
  id        String    @id @default(cuid())
  entryId   String
  /// "team_reroll" | "skill_reroll" | "assistant_coach"
  type      String    @default("team_reroll")
  /// "starter" | "purchased" | "achievement" | "mercato" | "reward"
  source    String    @default("starter")
  used      Boolean   @default(false)
  usedAt    DateTime?
  /// FK logique NflWeek.id quand consomme.
  weekId    String?
  /// FK logique NflFantasyMatchup.id quand consomme.
  matchupId String?
  /// NflPlayer.id sur lequel le reroll est applique (booste son SPP).
  appliedTo String?
  createdAt DateTime  @default(now())

  entry NflFantasyEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId, used])
}

model NflFantasyInducement {
  id        String   @id @default(cuid())
  entryId   String
  /// Type d'inducement choisi (InducementId catalogue 07-mechanics.md).
  type      String
  /// "defensive" | "offensive" | "wildcard"
  slot      String   @default("wildcard")
  /// "starter" | "purchased" | "achievement"
  source    String   @default("purchased")
  /// FK logique NflWeek.id pour le matchup ou il est joue.
  weekId    String
  /// FK logique NflFantasyMatchup.id.
  matchupId String
  /// NflPlayer.id cible (parfois).
  targetId  String?
  meta      Json?
  usedAt    DateTime @default(now())
  createdAt DateTime @default(now())

  entry NflFantasyEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId, weekId, matchupId])
}

// ─── Matchups + settlement (Phase 2.E) ──────────────────────────

model NflFantasyMatchup {
  id                 String    @id @default(cuid())
  leagueId           String
  /// FK logique NflWeek.id ("{year}:W{n}").
  weekId             String
  /// NflFantasyEntry.id de l'equipe home (premiere position pairing).
  homeEntryId        String
  /// NflFantasyEntry.id de l'equipe away.
  awayEntryId        String
  /// Set par settleNflFantasyWeek (sum des finalSpp des starters).
  homeScore          Int?
  awayScore          Int?
  /// NflFantasyEntry.id du winner ; null = tie ou non settle.
  winnerId           String?
  settledAt          DateTime?
  /// Gazette narrative generee post-settle par LLM (Phase 3.H). Null
  /// tant que pas genere. Idempotent : skip si gazetteGeneratedAt
  /// non-null sauf si force=true.
  gazetteTitle       String?
  gazetteBody        String?
  gazetteGeneratedAt DateTime?
  createdAt          DateTime  @default(now())

  league NflFantasyLeague @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([leagueId, weekId, homeEntryId, awayEntryId])
  @@index([leagueId, weekId])
  @@index([weekId, settledAt])
}

model NflFantasyLineupStarter {
  id            String  @id @default(cuid())
  lineupId      String
  playerId      String
  /// Position BB attribuee dans le lineup (Thrower, Catcher, Blitzer, ...).
  /// Snapshot au moment du setLineup pour eviter drift en cas de
  /// re-mapping NflPlayer.bbPosition entre semaines.
  bbPosition    String
  isCaptain     Boolean @default(false)
  isViceCaptain Boolean @default(false)
  /// Raw SPP du joueur sur la semaine (avant multipliers). Set par
  /// Phase 2.E settlement.
  rawSpp        Int?
  /// Final SPP apres captain/vice/rerolls/inducements/prayers.
  finalSpp      Int?
  sppBreakdown  Json?

  lineup NflFantasyLineup @relation(fields: [lineupId], references: [id], onDelete: Cascade)

  @@unique([lineupId, playerId])
  @@index([playerId])
}

// ─── Mercato V2 (encheres secretes asynchrones, MPG-style) ────────

/// Une session de mercato pour une league : fenetre temporelle pendant
/// laquelle les coachs posent des encheres secretes sur des joueurs.
/// A `closesAt`, la session est resolue : pour chaque joueur convoite,
/// l'enchere la plus haute remporte, tiebreaker = roster size puis
/// budget restant. Les bids perdants sont rembourses automatiquement
/// (puisque le budget n'est decremente qu'a la resolution).
model NflFantasyDraftSession {
  id            String    @id @default(cuid())
  leagueId      String
  /// Numero ordinal de la session (1, 2, 3...) pour affichage UI.
  sessionNumber Int
  opensAt       DateTime
  closesAt      DateTime
  resolvedAt    DateTime?
  /// "open" | "resolving" | "resolved" | "cancelled".
  status        String    @default("open")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  league NflFantasyLeague     @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  bids   NflFantasyDraftBid[]

  @@unique([leagueId, sessionNumber])
  @@index([status, closesAt])
}

/// Une enchere posee par un coach sur un joueur pendant une session.
/// Unique (sessionId, entryId, playerId) : un coach ne peut avoir qu'un
/// bid actif par player. Pour modifier, le service upsert. Pour
/// retirer, le service delete (avant resolution).
model NflFantasyDraftBid {
  id        String   @id @default(cuid())
  sessionId String
  entryId   String
  /// NflPlayer.id, FK logique.
  playerId  String
  /// Montant de l'enchere en TV. Doit etre >= prix de base + <= budget
  /// dispo (budgetRemaining moins somme des autres bids actifs).
  amount    Int
  /// "pending" (avant resolution) | "won" | "lost" (apres resolution).
  /// Permet de tracker historique pour audit / UI replay.
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session NflFantasyDraftSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  entry   NflFantasyEntry        @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@unique([sessionId, entryId, playerId])
  @@index([sessionId, playerId])
  @@index([entryId])
}

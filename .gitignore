coverage/
.nyc_output/
.jest/

# Lock files (keep only pnpm-lock.yaml)
package-lock.json
yarn.lock

# Database
*.db
*.sqlite
*.sqlite3

# Stray SQLite in-memory test DB artifacts (the server writes a file
# named after TEST_DATABASE_URL when it opens the connection). We keep
# memdb1 (used by tests/integration) under version control but ignore
# every other memdb-* file that may appear during local runs.
apps/server/prisma/sqlite/memdb-*

# Docker
.dockerignore
docker-compose.override.yml

# Prisma
prisma/migrations/
!prisma/migrations/.gitkeep

# Game specific
*.replay
*.save
logs/
screenshots/
/data/

# Development tools
.vscode/settings.json
.idea/
*.iml

# Deploy state (ecrit par scripts/deploy.sh apres chaque deploy reussi)
.last-deployed-commit
snapshots/

backups/

# Cache pnpm local (content-addressable store, ~1.4 GB).
# Cree quand pnpm install s'execute sans store-dir explicite, surtout
# depuis le container nufflearena_server via le bind mount `.:/app`.
.pnpm-store/

# Images de blog uploadées au runtime (cf. apps/server/src/routes/admin-blog.ts
# `POST /upload`). Le dossier n'est pas versionné : les nouveaux uploads sont
# ignorés. Quelques visuels historiques déjà commités y restent suivis, et le
# .gitkeep garantit l'existence du dossier (dossier d'upload par défaut en dev
# + chemin servi par le build web).
/apps/web/public/images/blog/*
!/apps/web/public/images/blog/.gitkeep

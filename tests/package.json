    "@vitest/coverage-v8": "^2.0.0",
    "jsdom": "^23.0.0",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^3.3.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vitest": "^2.1.9"
  }
